]],"version":548,"moveMidPointsWithElement":false,"elbowed":false,"type":"arrow","backgroundColor":"#ffec99","index":"b1J","roundness":{"type":2},"height":78.306169343204601,"link":null,"startArrowhead":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"endBinding":{"mode":"orbit","elementId":"MrS_8dSsxgR-mwJWrF9tj","fixedPoint":[1,0.50009999999999999]},"versionNonce":775869995,"frameId":null,"boundElements":[],"x":1385.5774219289494,"angle":0,"y":4374.8678727324859,"width":247.43605963844675},{"isDeleted":false,"locked":false,"strokeColor":"#1971c2","link":null,"roughness":2,"groupIds":[],"index":"b1K","backgroundColor":"transparent","angle":0,"fillStyle":"solid","strokeWidth":2,"version":833,"roundness":{"type":3},"type":"rectangle","updated":1776140902748,"id":"ewXeoGfhYpV0F41dkf0t1","x":621.80997473333514,"seed":1703870309,"boundElements":[],"y":3960.6749939521223,"opacity":100,"height":578.50085167895054,"width":1015.1862197463265,"frameId":null,"strokeStyle":"dashed","versionNonce":1073273035},{"seed":1317615045,"strokeStyle":"solid","id":"RnxiC0jqVrq-Q_pRTt6Qw","strokeWidth":2,"roughness":2,"isDeleted":false,"fontSize":20,"opacity":100,"verticalAlign":"top","updated":1776140902748,"locked":false,"text":"Redis can be used for leaderboards using sorted sets,\nwhich keep data in a sorted order and allow fast rank-based\nqueries. This makes them ideal for applications like rankings,\nwhere both reads and writes need to be very fast at scale.","version":826,"autoResize":true,"type":"text","backgroundColor":"#ffec99","index":"b1P","roundness":null,"containerId":null,"originalText":"Redis can be used for leaderboards using sorted sets,\nwhich keep data in a sorted order and allow fast rank-based\nqueries. This makes them ideal for applications like rankings,\nwhere both reads and writes need to be very fast at scale.","height":100,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":479823723,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1709.816840775926,"angle":0,"y":4102.1904571832092,"width":592.99951171875},{"seed":1500077573,"strokeStyle":"solid","id":"DfykuX3SiUh9yRQUfg6v8","strokeWidth":2,"roughness":2,"isDeleted":false,"fontSize":20,"opacity":100,"verticalAlign":"top","updated":1776140902748,"locked":false,"text":"For example, in a post search system, you can track posts\ncontaining a keyword like “tiger” and rank them by likes.\nEach post is added to a sorted set with its score as likes,\nso higher-liked posts automatically rank higher.","version":921,"autoResize":true,"type":"text","backgroundColor":"#ffec99","index":"b1Q","roundness":null,"containerId":null,"originalText":"For example, in a post search system, you can track posts\ncontaining a keyword like “tiger” and rank them by likes.\nEach post is added to a sorted set with its score as likes,\nso higher-liked posts automatically rank higher.","height":100,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":174809611,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1713.4484543499259,"angle":0,"y":4223.5270290504086,"width":583.49969482421875},{"seed":1117673029,"strokeStyle":"solid","id":"1jvTQ2aogh_Cta2wx1emw","strokeWidth":2,"roughness":2,"isDeleted":false,"fontSize":20,"opacity":100,"verticalAlign":"top","updated":1776140902748,"locked":false,"text":"Low-ranked entries can be periodically removed to save space,\nkeeping only the top results for efficiency.","version":1081,"autoResize":true,"type":"text","backgroundColor":"#ffec99","index":"b1R","roundness":null,"containerId":null,"originalText":"Low-ranked entries can be periodically removed to save space,\nkeeping only the top results for efficiency.","height":50,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":577300651,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1