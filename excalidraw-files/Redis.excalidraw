y":100,"verticalAlign":"top","updated":1776140902748,"locked":false,"text":"This is done using INCR to increase the \ncounter and EXPIRE to reset it after W \nseconds. If the value is within limits, the \nrequest is allowed.","version":520,"autoResize":true,"type":"text","backgroundColor":"#e6fcf5","index":"b1i","roundness":null,"containerId":null,"originalText":"This is done using INCR to increase the \ncounter and EXPIRE to reset it after W \nseconds. If the value is within limits, the \nrequest is allowed.","height":100,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":1049108203,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1743.0567820884814,"angle":0,"y":3481.3525561954571,"width":409.6197509765625},{"seed":1345497003,"strokeStyle":"solid","id":"B3bkeu1tUtCUGj9CXKmZP","strokeWidth":2,"roughness":2,"isDeleted":false,"fontSize":20,"opacity":100,"verticalAlign":"top","updated":1776140902748,"locked":false,"text":"For more accurate control, a sliding window\ncan be implemented using sorted sets where \ntimestamps are stored, old entries are \nremoved, and the remaining count is checked.","version":595,"autoResize":true,"type":"text","backgroundColor":"#e6fcf5","index":"b1j","roundness":null,"containerId":null,"originalText":"For more accurate control, a sliding window\ncan be implemented using sorted sets where \ntimestamps are stored, old entries are \nremoved, and the remaining count is checked.","height":100,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":832244107,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1740.8645060541501,"angle":0,"y":3617.5642400424622,"width":434.45968627929688},{"isDeleted":false,"locked":false,"strokeColor":"#1e1e1e","link":null,"roughness":2,"groupIds":[],"index":"b1k","backgroundColor":"transparent","angle":0,"fillStyle":"solid","strokeWidth":2,"version":537,"roundness":{"t