:[],"y":5423.3876405470073,"opacity":100,"height":0.12532526454924664,"points":[[0,0],[245.60224458067887,-0.12532526454924664]],"width":245.60224458067887,"frameId":null,"polygon":false,"strokeStyle":"dotted","versionNonce":1323011944},{"seed":191445951,"strokeStyle":"dotted","id":"sok_S-P2ZqMuA2wyAy1Bm","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":20,"opacity":100,"verticalAlign":"top","updated":1776182946094,"locked":false,"text":"Now in the follows table\nwe need to support two\ntypes of queries:\n- query all the users followed\n  by A\n- query all the users that\n  follow A","version":980,"autoResize":true,"type":"text","backgroundColor":"#e9ecef","index":"b0i","roundness":null,"containerId":null,"originalText":"Now in the follows table\nwe need to support two\ntypes of queries:\n- query all the users followed\n  by A\n- query all the users that\n  follow A","height":175,"link":null,"strokeColor":"#1971c2","fillStyle":"solid","groupIds":[],"versionNonce":377840232,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[{"id":"RVtQA9roIZ-RL7t2S8z-j","type":"arrow"}],"x":2619.9143735236044,"angle":0,"y":5365.4784730399806,"width":284.49981689453125},{"seed":980194239,"strokeStyle":"solid","id":"KMz76_BTc93RqERNuFhpO","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":20,"opacity":100,"verticalAlign":"top","updated":1776182946094,"locked":false,"text":"and on our GSI, we will\nchoose a different partition\nkey and sort key, and reverse\nthem - so our Pk would be \nuserFollowed and Sk would be\nuserFollowing","version":1356,"autoResize":true,"type":"text","backgroundColor":"#e9ecef","index":"b0k","roundness":null,"containerId":null,"originalText":"and on our GSI, we will\nchoose a different partition\nkey and sort key, and reverse\nthem - so our Pk would be \nuserFollowed and Sk would be\nuserFollowing","height":150,"link":null,"strokeColor":"#1971c2","fillStyle":"solid","groupIds":[],"versionNonce":259839336,"textA