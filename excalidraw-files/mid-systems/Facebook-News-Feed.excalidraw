0224458067887,"frameId":null,"polygon":false,"strokeStyle":"solid","versionNonce":677387368},{"seed":1283229823,"strokeStyle":"solid","id":"TYezpaiG5si5dW9XJv061","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":20,"opacity":100,"verticalAlign":"top","updated":1776182963794,"locked":false,"text":"Precomputed Feed\n\n- userId (Pk)\n- createdAt (Sk)\n- postId","version":637,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b2h","roundness":null,"containerId":null,"originalText":"Precomputed Feed\n\n- userId (Pk)\n- createdAt (Sk)\n- postId","height":125,"link":null,"strokeColor":"#e03131","fillStyle":"solid","groupIds":[],"versionNonce":1240485736,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[{"id":"EYwxQC2zt4WCI-dO6D52i","type":"arrow"}],"x":2089.3728136675559,"angle":0,"y":8455.7420931750166,"width":177.47987365722656},{"seed":265931551,"strokeStyle":"solid","id":"EYwxQC2zt4WCI-dO6D52i","strokeWidth":2,"roughness":1,"isDeleted":false,"startBinding":{"mode":"orbit","elementId":"_pFJiO_pp59bdp7V51Ey-","fixedPoint":[1.0394336310068024,0.49934370588851462]},"endArrowhead":"triangle","fixedSegments":null,"opacity":100,"startIsSpecial":null,"updated":1776182963794,"locked":false,"points":[[0,0],[77.728763979900577,0],[77.728763979900577,262.46627234834887],[155.4575279598007,262.46627234834887]],"endIsSpecial":null,"version":752,"elbowed":true,"type":"arrow","backgroundColor":"transparent","index":"b2i","roundness":null,"height":262.46627234834887,"link":null,"startArrowhead":"triangle","strokeColor":"#e03131","fillStyle":"solid","groupIds":[],"endBinding":{"mode":"orbit","elementId":"ZGyhHujKnxUwNRqniYAo6","fixedPoint":[-0.024032535264142629,0.78010746149025034]},"versionNonce":1359094376,"frameId":null,"boundElements":[],"x":1910.928321159317,"angle":0,"y":8310.2450756592734,"width":155.4575279598007},{"seed":1134640191,"strokeStyle":"solid","id":"1oXY_14Qzp-RrT2UUjSJ1","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":20,"opacity":100,"verticalAlign":"top","updated":1776182963794,"locked":false,"text":"When querying the\nfeed, the service can\ndirectly read from the\nprecomputed feed\ntable, making it very\nfast.\n","version":1106,"autoResize":false,"type":"text","backgroundColor":"transparent","index":"b2j","roundness":null,"containerId":null,"originalText":"When querying the feed, the service can directly read from the precomputed feed table, making it very fast.\n","height":175,"link":null,"strokeColor":"#1971c2","fillStyle":"solid","groupIds":[],"versionNonce":1549899112,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[{"id":"rIWwIpheK-CZZJTE0DU_y","type":"arrow"},{"id":"zSLIWI2Vu01PKD362sQtH","type":"arrow"}],"x":2235.4926937734067,"angle":0,"y":7781.2010421700506,"width":231.93938060023248},{"seed":1807490577,"strokeStyle":"solid","id":"2bhzpLoSuGspsxxe_qDsv","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":17.04958137494868,"opacity":100,"verticalAlign":"top","updated":1776182963794,"locked":false,"text":"We can store this in a separate \ncache, but here we use DynamoDB \nfor simplicity.\nWhen a post is created, we fetch \nall followers of the creator from \nthe follow GSI and then write \nthe post ID into each follower’s \nprecomputed feed table entry.","version":943,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b2l","roundness":null,"containerId":null,"originalText":"We can store this in a separate \ncache, but here we use DynamoDB \nfor simplicity.\nWhen a post is created, we fetch \nall followers of the creator from \nthe follow GSI and then write \nthe post ID into each follower’s \nprecomputed feed table entry.","height":170.49581374948684,"link":null,"strokeColor":"#1971c2","fillStyle":"solid","groupIds":[],"versionNonce":1364895848,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[{"id":"rIWwIpheK-CZZJTE0DU_y","type":"arrow"}],"x":1907.1984871351956,"angle":0,"y":7783.0291628187179,"width":291.68405917531754},{"seed":1972774577,"strokeStyle":"solid","id":"c6-Cu5UMHtLeHvjgjulPE","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":20,"opacity":100,"verticalAlign":"top","updated":1776182963794,"locked":false,"text":"While this improves read \nperformance significantly, \nit introduces a new problem.","version":744,"autoResize":true,"type":"text","backgroundColor":"#ffc9c9","index":"b2m","roundness":null,"containerId":null,"originalText":"While this improves read \nperformance significantly, \nit introduces a new problem.","height":75,"link":null,"strokeColor":"#1971c2","fillStyle":"solid","groupIds":[],"versionNonce":196696936,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":2502.6792352097395,"angle":0,"y":7755.8936259559014,"width":272.07980346679688},{"seed":1360958609,"strokeStyle":"solid","id":"3lTcqtNVdLBmtydjSJLbn","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":20,"opacity":100,"verticalAlign":"top","updated":1776182963794,"locked":false,"text":"When a user with 10,000 \nor more followers creates a \npost, the system has to write \ntens of thousands of precomputed \nfeed entries.\n\nThis creates a “fan-out \nexplosion” where rare \nhigh-follower accounts generate \na large burst of writes, \ncausing heavy load spikes.","version":577,"autoResize":true,"type":"text","backgroundColor":"#ffc9c9","index":"b2n","roundness":null,"containerId":null,"originalText":"When a user with 10,000 \nor more followers creates a \npost, the system has to write \ntens of thousands of precomputed \nfeed entries.\n\nThis creates a “fan-out \nexplosion” where rare \nhigh-follower accounts generate \na large burst of writes, \ncausing heavy load spikes.","height":275,"link":null,"strokeColor":"#1971c2","fillStyle":"solid","groupIds":[],"versionNonce":231321192,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":2673.2