":false,"fontSize":20,"opacity":100,"verticalAlign":"top","updated":1776182896203,"locked":false,"text":"By storing frequently accessed \nposts in memory with TTL + LFU \neviction, we offload traffic from \nthe database so only the cache serves \nmost requests, preventing \nthrottling on the hot partition.","version":859,"autoResize":true,"type":"text","backgroundColor":"#fff5f5","index":"b4G","roundness":null,"containerId":null,"originalText":"By storing frequently accessed \nposts in memory with TTL + LFU \neviction, we offload traffic from \nthe database so only the cache serves \nmost requests, preventing \nthrottling on the hot partition.","height":150,"link":null,"strokeColor":"#1971c2","fillStyle":"solid","groupIds":[],"versionNonce":740062744,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[{"id":"kWgq5PJ3SdU50VNk3Jp_D","type":"arrow"},{"id":"vK5pPzXa-ladkGNOnRdUA","type":"arrow"}],"x":1656.671022829812,"angle":0,"y":11019.437926383636,"width":388.8797607421875},{"isDeleted":false,"locked":false,"strokeColor":"#1e1e1e","link":null,"roughness":1,"groupIds":[],"index":"b4H","backgroundColor":"transparent","angle":0,"fillStyle":"solid","strokeWidth":2,"version":1958,"roundness":{"type":3},"type":"rectangle","updated":1776182896203,"id":"XbdODkXT0bvJqfyJ-z0O5","x":1771.0532264324752,"seed":478453183,"boundElements":[{"type":"text","id":"2AW_kJ_0WUDB-36xWB0iQ"},{"id":"oTaCUnXu4MoQSJRWFMBXs","type":"arrow"},{"id":"5dH0mc55L0z2L9dIG8iFX","type":"arrow"},{"id":"XKm5ZbapgP2mb-dE-NWhr","type":"arrow"}],"y":11305.978527352932,"opacity":100,"height":152.37071040374303,"width":152.15438819126211,"frameId":null,"strokeStyle":"solid","versionNonce":576058136},{"seed":1523092959,"strokeStyle":"solid","id":"2AW_kJ_0WUDB-36xWB0iQ","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":20,"opacity":100,"verticalAlign":"middle","updated":1776182896203,"locked":false,"text":"API\nGateway","version":1916,"autoResize":true,"type":"text","back