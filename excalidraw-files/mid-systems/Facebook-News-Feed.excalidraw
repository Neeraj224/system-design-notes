142629,0.69189350965352825]},"endArrowhead":"triangle","fixedSegments":[{"index":2,"start":[-118.13345925057183,0],"end":[-118.13345925057183,-453.77260141912575]},{"index":3,"start":[-118.13345925057183,-453.77260141912575],"end":[107.57239869279692,-453.77260141912575]}],"opacity":100,"startIsSpecial":false,"updated":1776182968154,"locked":false,"points":[[0,0],[-118.13345925057183,0],[-118.13345925057183,-453.77260141912575],[107.57239869279692,-453.77260141912575],[107.57239869279692,-548.37742461504968],[147.57239869279692,-548.37742461504968]],"endIsSpecial":false,"version":1235,"elbowed":true,"type":"arrow","backgroundColor":"#ffffff","index":"b3t","roundness":null,"height":548.37742461504968,"link":null,"startArrowhead":null,"strokeColor":"#e03131","fillStyle":"solid","groupIds":[],"endBinding":{"mode":"orbit","elementId":"NANyqBs9B2oWDQYymhyGl","fixedPoint":[-0.017503654045303293,0.49927561691933076]},"versionNonce":455279896,"frameId":null,"boundElements":[],"x":2519.3848525004023,"angle":0,"y":9775.3761643347825,"width":265.70585794336876},{"seed":1486180529,"strokeStyle":"solid","id":"3UJbpId5zNbHhvP-sYrS7","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":20,"opacity":100,"verticalAlign":"top","updated":1776182968154,"locked":false,"text":"We can solve our problem (fanout on write - \nthe problem being that when a user with \nmany followers posts, the system has to \nwrite that post to a very large number of \nusers’ precomputed feeds, causing heavy \nload and spikes) using an async worker pool.","version":625,"autoResize":true,"type":"text","backgroundColor":"#ffffff","index":"b3u","roundness":null,"containerId":null,"originalText":"We can solve our problem (fanout on write - \nthe problem being that when a user with \nmany followers posts, the system has to \nwrite that post to a very large number of \nusers’ precomputed feeds, causing heavy \nload and spikes) using an async worker pool.","height":150,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":800236056,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1472.960113737493,"angle":0,"y":9212.928587405062,"width":435.0997314453125},{"seed":693565375,"strokeStyle":"solid","id":"DUDbLTOSo0AdG239aAHLj","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":20,"opacity":100,"verticalAlign":"top","updated":1776182968154,"locked":false,"text":"We introduce a centralized\nqueue of post events, and\nfeed workers that consume\nfrom it.","version":1005,"autoResize":false,"type":"text","backgroundColor":"#ffffff","index":"b3v","roundness":null,"containerId":null,"originalText":"We introduce a centralized queue of post events, and feed workers that consume from it.","height":100,"link":null,"strokeColor":"#1971c2","fillStyle":"solid","groupIds":[],"versionNonce":709271320,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[{"id":"R2V1Hl3dxJ8QW--NVEPvA","type":"arrow"},{"id":"5zR8UcYhAZTTR2q23JQAc","type":"arrow"}],"x":1513.0293766675604,"angle":0,"y":9441.2021727967694,"width":284.14115981769555},{"seed":1516152881,"strokeStyle":"solid","id":"bvOR_dOnwix9WmpD3YduV","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":20,"opacity":100,"verticalAlign":"top","updated":1776182968154,"locked":false,"text":"When a post is created, we simply \npush a job into the queue instead \nof doing the fan-out synchronously.\nEach worker processes the job by \nreading followers from the follow \nGSI and writing the post ID into \ntheir precomputed feed. If the \nfollower list is large, the work \ncan be split into smaller sub-jobs \nand re-queued to distribute load \nacross multiple workers.","version":792,"autoResize":true,"type":"text","backgroundColor":"#ffffff","index":"b3w","roundness":null,"containerId":null,"originalText":"When a post is created, we simply \npush a job into the queue instead \nof doing the fan-out synchronously.\nEach worker processes the job by \nreading followers from the follow \nGSI and writing the post ID into \ntheir precomputed feed. If the \nfollower list is large, the work \ncan be split into smaller sub-jobs \nand re-queued to distribute load \nacross multiple workers.","height":275,"link":null,"strokeColor":"#1971c2","fillStyle":"solid","groupIds":[],"versionNonce":189987864,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[{"id":"5zR8UcYhAZTTR2q23JQAc","type":"arrow"},{"id":"8LlOGO2NgyfaBX3nOp0bP","type":"arrow"}],"x":1392.1665748482674,"angle":0,"y":9624.3138140705341,"width":350.45977783203125},{"seed":1395292703,"strokeStyle":"solid","id":"R2V1Hl3dxJ8QW--NVEPvA","strokeWidth":2,"roughness":1,"isDeleted":false,"startBinding":{"mode":"orbit","elementId":"L806B4o-5RUnxUSpmeKsW","fixedPoint":[-0.012793093700091957,0.49944029027507797]},"endArrowhead":"triangle","fixedSegments":null,"opacity":100,"startIsSpecial":null,"updated":1776182968154,"locked":false,"points":[[0,0],[-36,0],[-36,203.81330108125985],[56.918377340715779,203.81330108125985]],"endIsSpecial":null,"version":763,"elbowed":true,"type":"arrow","backgroundColor":"#ffffff","index":"b3x","roundness":null,"height":203.81330108125985,"link":null,"startArrowhead":null,"strokeColor":"#1971c2","fillStyle":"solid","groupIds":[],"endBinding":{"mode":"orbit","elementId":"DUDbLTOSo0AdG239aAHLj","fixedPoint":[-0.021116264901044408,0.49900000000000544]},"versionNonce":617330968,"frameId":null,"boundElements":[],"x":1450.1109993268446,"angle":0,"y":9287.288871715511,"width":92.918377340715779},{"seed":403424031,"strokeStyle":"solid","id":"5zR8UcYhAZTTR2q23JQAc","strokeWidth":2,"roughness":1,"isDeleted":false,"startBinding":{"mode":"orbit","elementId":"DUDbLTOSo0AdG239aAHLj","fixedPoint":[0.4996480622516512,1.0600000000000001]},"endArrowhead":"triangle","fixedSegments":null,"opacity":100,"startIsSpecial":null,"updated":1776182968154,"locked":false,"points":[[0,0],[0,35.555820636882345],[-119.85859715267998,35.555820636882345],[-119.85859715267998,71.111641273765599]],"endIsSpecial":null,"version":698,"elbowed":true,"type":"arrow","backgroundColor":"#ffffff","index":"b3y","roundness":null,"height":71.111641273765599,"link":null,"startArrowhead":null,"strokeColor":"#1971c2","fillStyle":"solid","groupIds":[],"endBinding":{"mode":"orbit","elementId":"bvOR_dOnwix9WmpD3YduV","fixedPoint":[0.4079634629112473,-0.02181818181818182]},"versionNonce":1780799000,"frameId":null,"boundElements":[],"x":1654.9999565764092,"angle":0,"y":9547.2021727967694,"width":119.85859715267998},{"isDeleted":false,"locked":false,"strokeColor":"#e03131","link":null,"roughness":1,"groupIds":[],"index":"b3z","backgroundColor":"#ffc9c9","angle":0,"fillStyle":"cross-hatch","strokeWidth":2,"version":1012,"roundness":{"type":3},"type":"rectangle","updated":1776182968154,"id":"Pma88tMhovZqTLFXHw43B","x":2480.7480820483788,"seed":987355327,"boundElements":[],"y":9175.0010695444507,"opacity":100,"height":79.525748097773459,"width":45.767489769776624,"frameId":null,"strokeStyle":"solid","versionNonce":1079137048},{"isDeleted":false,"locked":false,"strokeColor":"#e03131","link":null,"roughness":1,"groupIds":[],"index":"b40","backgroundColor":"#ffc9c9","angle":0,"fillStyle":"cross-hatch","strokeWidth":2,"version":1068,"roundness":{"type":3},"type":"rectangle","updated":1776182968154,"id":"-wmiA4JBz1S148pjaVySp","x":2418.9624483001326,"seed":677431857,"boundElements":[],"y":9175.177722697119,"opacity":100,"height":79.525748097773459,"width":45.767489769776624,"frameId":null,"strokeStyle":"solid","versionNonce":1304965144},{"isDeleted":false,"locked":false,"strokeColor":"#e03131","link":null,"roughness":1,"groupIds":[],"index":"b41","backgroundColor":"#ffc9c9","angle":0,"fillStyle":"cross-hatch","strokeWidth":2,"version":1125,"roundness":{"type":3},"type":"rectangle","updated":1776182968154,"id":"TJZ5WhaOtrVtnHfhdWQX0","x":2349.9308523527843,"seed":1773936767,"boundElements":[],"y":9174.9771974967916,"opacity":100,"height":79.525748097773459,"width":45.767489769776624,"frameId":null,"strokeStyle":"solid","versionNonce":1249537304},{"isDeleted":false,"locked":false,"strokeColor":"#e03131","link":null,"roughness":1,"groupIds":[],"index":"b42","backgroundColor":"#ffc9c9","angle":0,"fillStyle":"cross-hatch","strokeWidth":2,"version":1080,"roundness":{"type":3},"type":"rectangle","updated":1776182968154,"id":"3lP2SgRWxdBDyCeMSk6U-","x":2279.7343004797285,"seed":500513471,"boundElements":[],"y":9175.6838101074682,"opacity":100,"height":79.525748097773459,"width":45.767489769776624,"frameId":null,"strokeStyle":"solid","versionNonce":1339886104},{"seed":167759057,"strokeStyle":"solid","id":"py4insyjof3VzSdFvvGC3","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":20,"opacity":100,"verticalAlign":"top","updated":1776182968154,"locked":false,"text":"For very large accounts (hundreds of \nmillions of followers), pure fan-out \non write is not practical.\n\nSo we can use a hybrid approach:\nWe can add a flag in the follow table \nto indicate whether a feed should be \nprecomputed for that relationship. For \nnormal users, we can use the async \nfan-out and write posts into the \nprecomputed feed. For mega accounts \n(e.g. 100,000+ followers), we can \nskip precomputing.\n","version":787,"autoResize":true,"type":"text","backgroundColor":"#ffc9c9","index":"b44","roundness":null,"containerId":null,"originalText":"For very large accounts (hundreds of \nmillions of followers), pure fan-out \non write is not practical.\n\nSo we can use a hybrid approach:\nWe can add a flag in the follow table \nto indicate whether a feed should be \nprecomputed for that relationship. For \nnormal users, we can use the async \nfan-out and write posts into the \nprecomputed feed. For mega accounts \n(e.g. 100,000+ followers), we can \nskip precomputing.\n","height":350,"link":null,"strokeColor":"#1971c2","fillStyle":"cross-hatch","groupIds":[],"versionNonce":686032664,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[{"id":"8LlOGO2NgyfaBX3nOp0bP","type":"arrow"},{"id":"3M6Daz2jOh_Xt6o1nccML","type":"arrow"}],"x":1361.0162925677332,"angle":0,"y":9946.7790472087981,"width":384.6397705078125},{"seed":941924337,"strokeStyle":"solid","id":"V-4vyV9htZa0Nl6f4YyS6","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":20,"opacity":100,"verticalAlign":"top","updated":1776182968154,"locked":false,"text":"So, when a feed is requested, we:\n\n- Read precomputed feed entries for normal follows\n- Fetch recent posts on demand for mega accounts\n- Merge both results at runtime\n\nThis balances the system by reducing \nwrite amplification while still keeping \nreads fast.","version":829,"autoResize":false,"type":"text","backgroundColor":"#ffc9c9","index":"b45","roundness":null,"containerId":null,"originalText":"So, when a feed is requested, we:\n\n- Read precomputed feed entries for normal follows\n- Fetch recent posts on demand for mega accounts\n- Merge both results at runtime\n\nThis balances the system by reducing \nwrite amplification while still keeping \nreads fast.","height":225,"link":null,"strokeColor":"#1971c2","fillStyle":"cross-hatch","groupIds":[],"versionNonce":570647576,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[{"id":"3M6Daz2jOh_Xt6o1nccML","type":"arrow"}],"x":1838.7784035502309,"angle":0,"y":10043.815853917473,"width":509.63594715847995},{"seed":406384273,"strokeStyle":"solid","id":"8LlOGO2NgyfaBX3nOp0bP","strokeWidth":2,"roughness":1,"isDeleted":false,"startBinding":{"mode":"orbit","elementId":"bvOR_dOnwix9WmpD3YduV","fixedPoint":[-0.017120366956563233,0.49963636363636232]},"endArrowhead":"triangle","fixedSegments":null,"opacity":100,"startIsSpecial":null,"updated":1776182968154,"locked":false,"points":[[0,0],[-71.150282280534157,0],[-71.150282280534157,359.96523313826401],[-31.150282280534157,359.96523313826401]],"endIsSpecial":null,"version":451,"elbowed":true,"type":"arrow","backgroundColor":"#ffc9c9","index":"b46","roundness":null,"height":359.96523313826401,"link":null,"startArrowhead":null,"strokeColor":"#1971c2","fillStyle":"cross-hatch","groupIds":[],"endBinding":{"mode":"orbit","elementId":"py4insyjof3VzSdFvvGC3","fixedPoint":[-0.015599010970910853,0.49971428571428206]},"versionNonce":1496260888,"frameId":null,"boundElements":[],"x":1386.1665748482674,"angle":0,"y":9761.7138140705356,"width":71.150282280534157},{"seed":1678238847,"strokeStyle":"solid","id":"3M6Daz2jOh_Xt6o1nccML","strokeWidth":2,"roughness":1,"isDeleted":false,"startBinding":{"mode":"orbit","elementId":"py4insyjof3VzSdFvvGC3","fixedPoint":[1.0155990109709108,0.49971428571428206]},"endArrowhead":"triangle","fixedSegments":null,"opacity":100,"startIsSpecial":null,"updated":1776182968154,"locked":false,"points":[[0,0],[40.561170237343049,0],[40.561170237343049,34.536806708671975],[81.122340474686098,34.536806708671975]],"endIsSpecial":null,"version":394,"elbowed":true,"type":"arrow","backgroundColor":"#ffc9c9","index":"b47","roundness":null,"height":34.536806708671975,"link":null,"startArrowhead":null,"strokeColor":"#1971c2","fillStyle":"cross-hatch","groupIds":[],"endBinding":{"mode":"orbit","elementId":"V-4vyV9htZa0Nl6f4YyS6","fixedPoint":[-0.011773109870788213,0.49955555555554992]},"versionNonce":232472088,"frameId":null,"boundElements":[],"x":1751.6560630755457,"angle":0,"y":10121.6790472088,"width":81.122340474686098},{"seed":1473873905,"strokeStyle":"solid","id":"GaPkpA3gQna0kJWyGlj6E","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":20,"opacity":100,"verticalAlign":"top","updated":1776182896203,"locked":false,"text":"Now lets say if a viral post (e.g. from \nTaylor Swift) is published, a huge number \nof users suddenly try to fetch the same \npost ID from DynamoDB. This creates a \nmassive spike on a single partition, even \nthough the rest of the system is fine. \nSince DynamoDB requires relatively even \nload across partitions, that one \noverloaded shard gets throttled while \nothers stay idle.","version":762,"autoResize":true,"type":"text","backgroundColor":"#ffc9c9","index":"b48","roundness":null,"containerId":null,"originalText":"Now lets say if a viral post (e.g. from \nTaylor Swift) is published, a huge number \nof users suddenly try to fetch the same \npost ID from DynamoDB. This creates a \nmassive spike on a single partition, even \nthough the rest of the system is fine. \nSince DynamoDB requires relatively even \nload across partitions, that one \noverloaded shard gets throttled while \nothers stay idle.","height":250,"link":null,"strokeColor":"#1e1e1e","fillStyle":"cross-hatch","groupIds":[],"versionNonce":1365543704,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[{"id":"3VYqH8kg6XoXNMjWBF16p","type":"arrow"}],"x":1306.9091364096016,"angle":0,"y":10650.44667837407,"width":408.979736328125},{"isDeleted":false,"locked":false,"strokeColor":"#1e1e1e","link":null,"roughness":1,"groupIds":[],"index":"b4A","backgroundColor":"#ffd43b","angle":0,"fillStyle":"solid","strokeWidth":2,"version":1722,"roundness":{"type":3},"type":"rectangle","updated":1776182896203,"id":"fcF8GN6yMBSKSYpW1ShIA","x":1264.9523009565924,"seed":1863000081,"boundElements":[],"y":10547.910421889675,"opacity":100,"height":52.14340591569335,"width":479.20768206948378,"frameId":null,"strokeStyle":"solid","versionNonce":1876125720},{"seed":1504638449,"strokeStyle":"solid","id":"qcxQjlcr7PoNJS45eMIMq","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":28,"opacity":100,"verticalAlign":"top","updated":1776182896203,"locked":false,"text":"Step Five: Adding a Cache Layer!","version":1646,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b4B","roundness":null,"containerId":null,"originalText":"Step Five: Adding a Cache Layer!","height":35,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":1985914136,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"