isDeleted":false,"fontSize":20,"opacity":100,"verticalAlign":"top","updated":1776182955956,"locked":false,"text":"Now, to support pagination for an \ninfinite scroll experience,\nwe use a cursor to track the \noldest timestamp the user\nhas seen in their feed.\nWe need to use this timestamp \nas a filter to fetch the next\nset of posts.","version":525,"autoResize":true,"type":"text","backgroundColor":"#e9ecef","index":"b1p","roundness":null,"containerId":null,"originalText":"Now, to support pagination for an \ninfinite scroll experience,\nwe use a cursor to track the \noldest timestamp the user\nhas seen in their feed.\nWe need to use this timestamp \nas a filter to fetch the next\nset of posts.","height":200,"link":null,"strokeColor":"#1971c2","fillStyle":"solid","groupIds":[],"versionNonce":2010971672,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[{"id":"ONvg76Ju4lQ_yelFq-cVi","type":"arrow"},{"id":"qQIYrcZm0xjH4UIB5CGuN","type":"arrow"}],"x":2636.0653100160812,"angle":0,"y":6998.6219659540175,"width":340.85980224609375},{"seed":627515985,"strokeStyle":"solid","id":"Q7sG-Hep6_p4og5TOre10","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":20,"opacity":100,"verticalAlign":"top","updated":1776182955956,"locked":false,"text":"We use a cursor representing the oldest timestamp\nthe user has seen in their feed. This timestamp is\nused as a filter when fetching posts.\nWhile querying the post GSI for followed users,\nwe fetch up to the page size where createdAt\nis less than the cursor.\n\nThis would give use the most recent \nposts before that time - giving us \ninfinite scroll pagination.","version":800,"autoResize":false,"type":"text","backgroundColor":"#e9ecef","index":"b1q","roundness":null,"containerId":null,"originalText":"We use a cursor representing the oldest timestamp\nthe user has seen in their feed. This timestamp is\nused as a filter when fetching posts.\nWhile querying the post GSI for followed users,\nwe fetch up to the page size where createdAt\nis less than the cursor.\n\nThis would give use the most recent \nposts before that time - giving us \ninfinite scroll pagination.","height":250,"link":null,"strokeColor":"#1971c2","fillStyle":"solid","groupIds":[],"versionNonce":885357336,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[{"id":"qQIYrcZm0xjH4UIB5CGuN","type":"arrow"}],"x":2046.3377728621908,"angle":0,"y":7111.5606341366029,"width":512.04374019892805},{"seed":1031983089,"strokeStyle":"solid","id":"ONvg76Ju4lQ_yelFq-cVi","strokeWidth":2,"roughness":1,"isDeleted":false,"startBinding":{"mode":"orbit","elementId":"pZBesnMHzvR8nNLwhxTaG","fixedPoint":[0.4997925309627026,1.24]},"endArrowhead":"triangle","fixedSegments":null,"opacity":100,"startIsSpecial":null,"updated":1776182955956,"locked":false,"points":[[0,0],[0,23.435350194959938],[-7.3837430367739216,23.435350194959938],[-7.3837430367739216,47.53736705658639]],"endIsSpecial":null,"version":410,"elbowed":true,"type":"arrow","backgroundColor":"#e9ecef","index":"b1r","roundness":null,"height":47.53736705658639,"link":null,"startArrowhead":null,"strokeColor":"#1971c2","fillStyle":"solid","groupIds":[],"endBinding":{"mode":"orbit","elementId":"psYt8Jiq7Zuiwi-5quvVI","fixedPoint":[0.69451240979783502,-0.026666666666666668]},"versionNonce":429283352,"frameId":null,"boundElements":[],"x":2880.1804157140032,"angle":0,"y":6945.7512655640976,"width":7.3837430367739216},{"seed":658080401,"strokeStyle":"solid","id":"qQIYrcZm0xjH4UIB5CGuN","strokeWidth":2,"roughness":1,"isDeleted":false,"startBinding":{"mode":"orbit","elementId":"psYt8Jiq7Zuiwi-5quvVI","fixedPoint":[0.49970662425037948,1.0300000000000069]},"endArrowhead":"triangle","fixedSegments":null,"opacity":100,"startIsSpecial":null,"updated":1776182955956,"locked":false,"points":[[0,0],[0,51.178009189266959],[-241.81561790916385,51.178009189266959]],"endIsSpecial":null,"version":1136,"elbowed":true,"type":"arrow","backgroundColor":"#e9ecef","index":"b1s","roundness":null,"height":51.178009189266959,"link":null,"startArrowhead":null,"strokeColor":"#1971c2","fillStyle":"solid","groupIds":[],"endBinding":{"mode":"orbit","elementId":"Q7sG-Hep6_p4og5TOre10","fixedPoint":[1.0121045912336282,0.57695736402672992]},"versionNonce":1245943064,"frameId":null,"boundElements":[],"x":2806.3952111391286,"angle":0,"y":7204.6219659540184,"width":241.81561790916385},{"isDeleted":false,"locked":false,"strokeColor":"#1e1e1e","link":null,"roughness":1,"groupIds":[],"index":"b1t","backgroundColor":"#ffd43b","angle":0,"fillStyle":"solid","strokeWidth":2,"version":1194,"roundness":{"type":3},"type":"rectangle","updated":1776182963794,"id":"OiIAiCrLPJES5YMfZ52Jj","x":1380.7826850437127,"seed":1666246719,"boundElements":[],"y":7529.359512488184,"opacity":100,"height":52.14340591569335,"width":394.15091853718155,"frameId":null,"strokeStyle":"solid","versionNonce":678486888},{"seed":1185384543,"strokeStyle":"solid","id":"TvGXu57mkHkYQ_qfRvNMd","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":28,"opacity":100,"verticalAlign":"top","updated":1776182963794,"locked":false,"text":"Step Three: Scaling it out!","version":1064,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b1u","roundness":null,"containerId":null,"originalText":"Step Three: Scaling it out!","height":35,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":978335336,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1394.9123181837872,"angle":0,"y":7536.3240629915672,"width":365.8758544921875},{"isDeleted":false,"locked":false,"strokeColor":"#1971c2","link":null,"roughness":1,"groupIds":[],"index":"b1v","backgroundColor":"transparent","angle":0,"fillStyle":"solid","strokeWidth":2,"version":445,"roundness":{"type":3},"type":"rectangle","updated":1776182955956,"id":"G0vawxTFxo95m3ZCfJplZ","x":2028.7907474322274,"seed":1236227391,"boundElements":[],"y":7105.1453800629051,"opacity":100,"height":257.73273381641138,"width":533.68914614548112,"frameId":null,"strokeStyle":"dotted","versionNonce":1279341080},{"isDeleted":false,"locked":false,"strokeColor":"#1971c2","link":null,"roughness":1,"groupIds":[],"index":"b1x","backgroundColor":"transparent","angle":0,"fillStyle":"solid","strokeWidth":2,"version":551,"roundness":{"type":3},"type":"rectangle","updated":1776182955956,"id":"Y4siF6LPQe26UOfEg4muw","x":2624.9999153970498,"seed":174590495,"boundElements":[],"y":6994.0710955604109,"opacity":100,"height":206.58169719285115,"width":360.613410111544,"frameId":null,"strokeStyle":"dotted","versionNonce":1451437848},{"seed":782654847,"strokeStyle":"dotted","id":"aCp8v2_Mn1yXXN4MjiDrH","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":20,"opacity":100,"verticalAlign":"top","updated":1776182963794,"locked":false,"text":"If a user follows 10,000 people, the system would\nneed to make 10,000 requests to fetch posts,\nresulting in millions of posts that must be merged\nand sorted in near real time.\nThis creates high network overhead, heavy computation,\nand increases the risk of latency and failures.","version":649,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b1y","roundness":null,"containerId":null,"originalText":"If a user follows 10,000 people, the system would\nneed to make 10,000 requests to fetch posts,\nresulting in millions of posts that must be merged\nand sorted in near real time.\nThis creates high network overhead, heavy computation,\nand increases the risk of latency and failures.","height":150,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":449653096,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1377.2312352849945,"angle":0,"y":7616.0365419630398,"width":551.03961181640625},{"seed":2121575953,"strokeStyle":"dotted","id":"chV9PC2YIfnDCxL6IUYuM","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":20,"opacity":100,"verticalAlign":"top","updated":1776182963794,"locked":false,"text":"Instead of building\nthe feed at read time,\nwe can compute it at\nwrite time when a\npost is created.","version":1401,"autoResize":false,"type":"text","backgroundColor":"transparent","index":"b24","roundness":null,"containerId":null,"originalText":"Instead of building the feed at read time,\nwe can compute it at write time when a post is created.","height":125,"link":null,"strokeColor":"#1971c2","fillStyle":"solid","groupIds":[],"versionNonce":1697889384,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1372.5420086391146,"angle":0,"y":7815.245649897186,"width":223.69954811894559},{"seed":760036127,"strokeStyle":"dotted","id":"26cPWJIlAOxHBvLVIU5fs","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":20,"opacity":100,"verticalAlign":"top","updated":1776182963794,"locked":false,"text":"This means we can\nintroduce a new table\ncalled a Precomputed\nFeed, where each user\nalready has their feed\ndata stored.","version":1328,"autoResize":false,"type":"text","backgroundColor":"transparent","index":"b2B","roundness":null,"containerId":null,"originalText":"This means we can introduce a new table called a Precomputed Feed, where each user already has their feed data stored.","height":150,"link":null,"strokeColor":"#1971c2","fillStyle":"solid","groupIds":[],"versionNonce":1800400744,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[{"id":"4mkk3UxkqzFgg_y2ErfZo","type":"arrow"}],"x":1637.3014608003809,"angle":0,"y":7806.0368783480526,"width":257.71626490206688},{"isDeleted":false,"locked":false,"strokeColor":"#1e1e1e","link":null,"roughness":1,"groupIds":[],"index":"b2C","backgroundColor":"transparent","angle":0,"fillStyle":"solid","strokeWidth":2,"version":955,"roundness":{"type":3},"type":"rectangle","updated":1776182963794,"id":"SEgUrrfU7Vyom9XjYYAKG","x":1385.4431333622992,"seed":2018106335,"boundElements":[{"type":"te