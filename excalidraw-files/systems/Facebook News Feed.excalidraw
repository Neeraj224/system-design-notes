whead":null,"backgroundColor":"transparent","endBinding":null,"angle":0,"fillStyle":"solid","strokeWidth":2,"version":1054,"roundness":{"type":2},"type":"line","updated":1776156119347,"id":"ybQXB0FqGskHN8bkqHSPp","x":5160.1040794809887,"seed":342220799,"boundElements":[],"y":2934.7028756585696,"opacity":100,"height":0.12532526454924664,"points":[[0,0],[245.60224458067887,-0.12532526454924664]],"width":245.60224458067887,"frameId":null,"polygon":false,"strokeStyle":"solid","versionNonce":1022137425},{"seed":1283229823,"strokeStyle":"solid","id":"TYezpaiG5si5dW9XJv061","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":20,"opacity":100,"verticalAlign":"top","updated":1776156119347,"locked":false,"text":"Precomputed Feed\n\n- userId (Pk)\n- createdAt (Sk)\n- postId","version":398,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b2h","roundness":null,"containerId":null,"originalText":"Precomputed Feed\n\n- userId (Pk)\n- createdAt (Sk)\n- postId","height":125,"link":null,"strokeColor":"#e03131","fillStyle":"solid","groupIds":[],"versionNonce":198697521,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[{"id":"EYwxQC2zt4WCI-dO6D52i","type":"arrow"}],"x":5176.5781561913773,"angle":0,"y":2906.9462064659829,"width":177.47987365722656},{"seed":265931551,"strokeStyle":"solid","id":"EYwxQC2zt4WCI-dO6D52i","strokeWidth":2,"roughness":1,"isDeleted":false,"startBinding":{"mode":"orbit","elementId":"_pFJiO_pp59bdp7V51Ey-","fixedPoint":[1.0394336310068024,0.49934370588851462]},"endArrowhead":"triangle","fixedSegments":null,"opacity":100,"startIsSpecial":null,"updated":1776156119347,"locked":false,"points":[[0,0],[77.728763979900577,0],[77.728763979900577,262.46627234834887],[155.4575279598007,262.46627234834887]],"endIsSpecial":null,"version":513,"elbowed":true,"type":"arrow","backgroundColor":"transparent","index":"b2i","roundness":null,"height":262.46627234834887,"link":null,"startArrowhead":"triangle","strokeColor":"#e03131","fillStyle":"solid","groupIds":[],"endBinding":{"mode":"orbit","elementId":"ZGyhHujKnxUwNRqniYAo6","fixedPoint":[-0.024032535264142629,0.78010746149025034]},"versionNonce":1608414225,"frameId":null,"boundElements":[],"x":4998.1336636831384,"angle":0,"y":2761.4491889502415,"width":155.4575279598007},{"seed":1134640191,"strokeStyle":"solid","id":"1oXY_14Qzp-RrT2UUjSJ1","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":20,"opacity":100,"verticalAlign":"top","updated":1776156119347,"locked":false,"text":"When querying the\nfeed, the service can\ndirectly read from the\nprecomputed feed\ntable, making it very\nfast.\n","version":867,"autoResize":false,"type":"text","backgroundColor":"transparent","index":"b2j","roundness":null,"containerId":null,"originalText":"When querying the feed, the service can directly read from the precomputed feed table, making it very fast.\n","height":175,"link":null,"strokeColor":"#1971c2","fillStyle":"solid","groupIds":[],"versionNonce":2096613873,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[{"id":"rIWwIpheK-CZZJTE0DU_y","type":"arrow"},{"id":"zSLIWI2Vu01PKD362sQtH","type":"arrow"}],"x":5322.6980362972281,"angle":0,"y":2232.4051554610178,"width":231.93938060023248},{"seed":1807490577,"strokeStyle":"solid","id":"2bhzpLoSuGspsxxe_qDsv","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":17.04958137494868,"opacity":100,"verticalAlign":"top","updated":1776156119347,"locked":false,"text":"We can store this in a separate \ncache, but here we use DynamoDB \nfor simplicity.\nWhen a post is created, we fetch \nall followers of the creator from \nthe follow GSI and then write \nthe post ID into each follower’s \nprecomputed feed table entry.","version":704,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b2l","roundness":null,"containerId":null,"originalText":"We can store this in a separate \ncache, but here we use DynamoDB \nfor simplicity.\nWhen a post is created, we fetch \nall followers of the creator from \nthe follow GSI and then write \nthe post ID into each follower’s \nprecomputed feed table entry.","height":170.49581374948684,"link":null,"strokeColor":"#1971c2","fillStyle":"solid","groupIds":[],"versionNonce":1009476561,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[{"id":"rIWwIpheK-CZZJTE0DU_y","type":"arrow"}],"x":4994.403829659017,"angle":0,"y":2234.233276109685,"width":291.68405917531754},{"seed":1972774577,"strokeStyle":"solid","id":"c6-Cu5UMHtLeHvjgjulPE","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":20,"opacity":100,"verticalAlign":"top","updated":1776156119347,"locked":false,"text":"While this improves read \nperformance significantly, \nit introduces a new problem.","version":505,"autoResize":true,"type":"text","backgroundColor":"#ffc9c9","index":"b2m","roundness":null,"containerId":null,"originalText":"While this improves read \nperformance significantly, \nit introduces a new problem.","height":75,"link":null,"strokeColor":"#1971c2","fillStyle":"solid","groupIds":[],"versionNonce":1771094449,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":5589.8845777335609,"angle":0,"y":2207.0977392468685,"width":272.07980346679688},{"seed":1360958609,"strokeStyle":"solid","id":"3lTcqtNVdLBmtydjSJLbn","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":20,"opacity":100,"verticalAlign":"top","updated":1776156119347,"locked":false,"text":"When a user with 10,000 \nor more followers creates a \npost, the system has to write \ntens of thousands of precomputed \nfeed entries.\n\nThis creates a “fan-out \nexplosion” where rare \nhigh-follower accounts generate \na large burst of writes, \ncausing heavy load spikes.","version":338,"autoResize":true,"type":"text","backgroundColor":"#ffc9c9","index":"b2n","roundness":null,"containerId":null,"originalText":"When a user with 10,000 \nor more followers creates a \npost, the system has to write \ntens of thousands of precomputed \nfeed entries.\n\nThis creates a “fan-out \nexplosion” where rare \nhigh-follower accounts generate \na large burst of writes, \ncausing heavy load spikes.","height":275,"link":null,"strokeColor":"#1971c2","fillStyle":"solid","groupIds":[],"versionNonce":1649370001,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":5760.4530196598189,"angle":0,"y":2371.6435045614544,"width":348.539794921875},{"isDeleted":false,"locked":false,"strokeColor":"#1971c2","link":null,"roughness":1,"groupIds":[],"index":"b2o","backgroundColor":"transparent","angle":0,"fillStyle":"solid","strokeWidth":2,"version":418,"roundness":{"type":3},"type":"rectangle","updated":1776156119347,"id":"qkIkoKunW5G_ZyyQjTce9","x":5580.2628156235096,"seed":286409311,"boundElements":[{"id":"0XBtLJAnnGvLzTCX_7q-9","type":"arrow"},{"id":"zSLIWI2Vu01PKD362sQtH","type":"arrow"}],"y":2199.7405784388975,"opacity":100,"height":87.066226002702024,"width":287.72505390710739,"frameId":null,"strokeStyle":"dotted","versionNonce":1923008881},{"isDeleted":false,"locked":false,"strokeColor":"#1971c2","link":null,"roughness":1,"groupIds":[],"index":"b2p","backgroundColor":"transparent","angle":0,"fillStyle":"solid","strokeWidth":2,"version":443,"roundness":{"type":3},"type":"rectangle","updated":1776156119347,"id":"Fn3tiuCsYtmc5uaR5lq6c","x":5744.6744209863109,"seed":1195083295,"boundElements":[{"id":"0XBtLJAnnGvLzTCX_7q-9","type":"arrow"},{"id":"LjHpfja1j53VlH7cQEhLn","type":"arrow"}],"y":2360.8391674481481,"opacity":100,"height":296.39493001262684,"width":368.72810827575131,"frameId":null,"strokeStyle":"dotted","versionNonce":1942385489},{"seed":1935767025,"strokeStyle":"solid","id":"0XBtLJAnnGvLzTCX_7q-9","strokeWidth":2,"roughness":1,"isDeleted":false,"startBinding":{"mode":"orbit","elementId":"qkIkoKunW5G_ZyyQjTce9","fixedPoint":[1.0208532413793119,0.49885144901081091]},"endArrowhead":"triangle","fixedSegments":null,"opacity":100,"sta