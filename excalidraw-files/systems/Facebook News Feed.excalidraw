nt":[1.0240325352641448,0.4994108049413723]},"versionNonce":1918231537,"frameId":null,"boundElements":[],"x":6207.8478699520656,"angle":0,"y":3702.7091698520189,"width":368.67874662970644},{"seed":1984502161,"strokeStyle":"solid","id":"AkCPMqFRxqPKnuTJpmCbY","strokeWidth":2,"roughness":1,"isDeleted":false,"startBinding":{"mode":"orbit","elementId":"UayvtO_x1SnBH_j13d7qL","fixedPoint":[-0.024032535264142629,0.69189350965352825]},"endArrowhead":"triangle","fixedSegments":[{"index":2,"start":[-118.13345925057183,0],"end":[-118.13345925057183,-453.77260141912575]},{"index":3,"start":[-118.13345925057183,-453.77260141912575],"end":[107.57239869279692,-453.77260141912575]}],"opacity":100,"startIsSpecial":false,"updated":1776155981651,"locked":false,"points":[[0,0],[-118.13345925057183,0],[-118.13345925057183,-453.77260141912575],[107.57239869279692,-453.77260141912575],[107.57239869279692,-548.37742461504968],[147.57239869279692,-548.37742461504968]],"endIsSpecial":false,"version":988,"elbowed":true,"type":"arrow","backgroundColor":"#ffffff","index":"b3t","roundness":null,"height":548.37742461504968,"link":null,"startArrowhead":null,"strokeColor":"#e03131","fillStyle":"solid","groupIds":[],"endBinding":{"mode":"orbit","elementId":"NANyqBs9B2oWDQYymhyGl","fixedPoint":[-0.017503654045303293,0.49927561691933076]},"versionNonce":1387675089,"frameId":null,"boundElements":[],"x":5705.4899029161588,"angle":0,"y":4251.0865944670686,"width":265.70585794336876},{"seed":1486180529,"strokeStyle":"solid","id":"3UJbpId5zNbHhvP-sYrS7","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":20,"opacity":100,"verticalAlign":"top","updated":1776155981651,"locked":false,"text":"We can solve our problem (fanout on write - \nthe problem being that when a user with \nmany followers posts, the system has to \nwrite that post to a very large number of \nusers’ precomputed feeds, causing heavy \nload and spikes) using an async worker pool.","version":378,"autoResize":true,"type":"text","backgroundColor":"#ffffff","index":"b3u","roundness":null,"containerId":null,"originalText":"We can solve our problem (fanout on write - \nthe problem being that when a user with \nmany followers posts, the system has to \nwrite that post to a very large number of \nusers’ precomputed feeds, causing heavy \nload and spikes) using an async worker pool.","height":150,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":1571838897,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":4659.0651641532495,"angle":0,"y":3688.6390175373481,"width":435.0997314453125},{"seed":693565375,"strokeStyle":"solid","id":"DUDbLTOSo0AdG239aAHLj","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":20,"opacity":100,"verticalAlign":"top","updated":1776155981651,"locked":false,"text":"We introduce a centralized\nqueue of post events, and\nfeed workers that consume\nfrom it.","version":758,"autoResize":false,"type":"text","backgroundColor":"#ffffff","index":"b3v","roundness":null,"containerId":null,"originalText":"We introduce a centralized queue of post events, and feed workers that consume from it.","height":100,"link":null,"strokeColor":"#1971c2","fillStyle":"solid","groupIds":[],"versionNonce":594263441,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[{"id":"R2V1Hl3dxJ8QW--NVEPvA","type":"arrow"},{"id":"5zR8UcYhAZTTR2q23JQAc","type":"arrow"}],"x":4699.134427083317,"angle":0,"y":3916.9126029290546,"width":284.14115981769555},{"seed":1516152881,"strokeStyle":"solid","id":"bvOR_dOnwix9WmpD3YduV","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":20,"opacity":100,"verticalAlign":"top","updated":1776155981651,"locked":false,"text":"When a post is created, we simply \npush a job into the queue instead \nof doing the fan-out synchronously.\nEach worker processes the job by \nreading followers from the follow \nGSI and writing the post ID into \ntheir precomputed feed. If the \nfollower list is large, the work \ncan be split into smaller sub-jobs \nand re-queued to distribute load \nacross multiple workers.","version":545,"autoResize":true,"type":"text","backgroundColor":"#ffffff","index":"b3w","roundness":null,"containerId":null,"originalText":"When a post is created, we simply \npush a job into the queue instead \nof doing the fan-out synchronously.\nEach worker processes the job by \nreading followers from the follow \nGSI and writing the post ID into \ntheir precomputed feed. If the \nfollower list is large, the work \ncan be split into smaller sub-jobs \nand re-queued to distribute load \nacross multiple workers.","height":275,"link":null,"strokeColor":"#1971c2","fillStyle":"solid","groupIds":[],"versionNonce":1126163313,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[{"id":"5zR8UcYhAZTTR2q23JQAc","type":"arrow"},{"id":"8LlOGO2NgyfaBX3nOp0bP","type":"arrow"}],"x":4578.2716252640239,"angle":0,"y":4100.0242442028202,"width":350.45977783203125},{"seed":1395292703,"strokeStyle":"solid","id":"R2V1Hl3dxJ8QW--NVEPvA","strokeWidth":2,"roughness":1,"isDeleted":false,"startBinding":{"mode":"orbit","elementId":"L806B4o-5RUnxUSpmeKsW","fixedPoint":[-0.012793093700091957,0.49944029027507797]},"endArrowhead":"triangle","fixedSegments":null,"opacity":100,"startIsSpecial":null,"updated":1776155981651,"locked":false,"points":[[0,0],[-36,0],[-36,203.81330108125985],[56.918377340715779,203.81330108125985]],"endIsSpecial":null,"version":516,"elbowed":true,"type":"arrow","backgroundColor":"#ffffff","index":"b3x","roundness":null,"height":203.81330108125985,"link":null,"startArrowhead":null,"strokeColor":"#1971c2","fillStyle":"solid","groupIds":[],"endBinding":{"mode":"orbit","elementId":"DUDbLTOSo0AdG239aAHLj","fixedPoint":[-0.021116264901044408,0.49900000000000544]},"versionNonce":152325457,"frameId":null,"boundElements":[],"x":4636.2160497426012,"angle":0,"y":3762.9993018477953,"width":92.918377340715779},{"seed":403424031,"strokeStyle":"solid","id":"5zR8UcYhAZTTR2q23JQAc","strokeWidth":2,"roughness":1,"isDeleted":false,"startBinding":{"mode":"orbit","elementId":"DUDbLTOSo0AdG239aAHLj","fixedPoint":[0.4996480622516512,1.0600000000000001]},"endArrowhead":"triangle","fixedSegments":null,"opacity":100,"startIsSpecial":null,"updated":1776155981651,"locked":false,"points":[[0,0],[0,35.555820636882345],[-119.85859715267998,35.555820636882345],[-119.85859715267998,71.111641273765599]],"endIsSpecial":null,"version":451,"elbowed":true,"type":"arrow","backgroundColor":"#ffffff","index":"b3y","roundness":null,"height":71.111641273765599,"link":null,"startArrowhead":null,"strokeColor":"#1971c2","fillStyle":"solid","groupIds":[],"endBinding":{"mode":"orbit","elementId":"bvOR_dOnwix9WmpD3YduV","fixedPoint":[0.4079634629112473,-0.02181818181818182]},"versionNonce":1285585713,"frameId":null,"boundElements":[],"x":4841.1050069921657,"angle":0,"y":4022.9126029290546,"width":119.85859715267998},{"isDeleted":false,"locked":false,"strokeColor":"#e03131","link":null,"roughness":1,"groupIds":[],"index":"b3z","backgroundColor":"#ffc9c9","angle":0,"fillStyle":"cross-hatch","strokeWidth":2,"version":765,"roundness":{"type":3},"type":"rectangle","updated":1776155981651,"id":"Pma88tMhovZqTLFXHw43B","x":5666.8531324641353,"seed":987355327,"boundElements":[],"y":3650.7114996767368,"opacity":100,"height":79.525748097773459,"width":45.767489769776624,"frameId":null,"strokeStyle":"solid","versionNonce":237759761},{"isDeleted":false,"locked":false,"strokeColor":"#e03131","link":null,"roughness":1,"groupIds":[],"index":"b40","backgroundColor":"#ffc9c9","angle":0,"fillStyle":"cross-hatch","strokeWidth":2,"version":821,"roundness":{"type":3},"type":"rectangle","updated":1776155981651,"id":"-wmiA4JBz1S148pjaVySp","x":5605.0674987158891,"seed":677431857,"boundElements":[],"y":3650.8881528294041,"opacity":100,"height":79.525748097773459,"width":45.767489769776624,"frameId":null,"strokeStyle":"solid","versionNonce":1429086961},{"isDeleted":false,"locked":false,"strokeColor":"#e03131","link":null,"roughness":1,"groupIds":[],"index":"b41","backgroundColor":"#ffc9c9","angle":0,"fillStyle":"cross-hatch","strokeWidth":2,"version":878,"roundness":{"type":3},"type":"rectangle","updated":1776155981651,"id":"TJZ5WhaOtrVtnHfhdWQX0","x":5536.0359027685408,"seed":1773936767,"boundElements":[],"y":3650.6876276290777,"opacity":100,"height":79.525748097773459,"width":45.767489769776624,"frameId":null,"strokeStyle":"solid","versionNonce":1311677649},{"isDeleted":false,"locked":false,"strokeColor":"#e03131","link":null,"roughness":1,"groupIds":[],"index":"b42","backgroundColor":"#ffc9c9","angle":0,"fillStyle":"cross-hatch","strokeWidth":2,"version":833,"roundness":{"type":3},"type":"rectangle","updated":1776155981651,"id":"3lP2SgRWxdBDyCeMSk6U-","x":5465.839350895485,"seed":500513471,"boundElements":[],"y":3651.3942402397533,"opacity":100,"height":79.525748097773459,"width":45.767489769776624,"frameId":null,"strokeStyle":"solid","versionNonce":683989681},{"seed":167759057,"strokeStyle":"solid","id":"py4insyjof3VzSdFvvGC3","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":20,"opacity":100,"verticalAlign":"top","updated":1776155981651,"locked":false,"text":"For very large accounts (hundreds of \nmillions of followers), pure fan-out \non write is not practical.\n\nSo we can use a hybrid approach:\nWe can add a flag in the follow table \nto indicate whether a feed should be \nprecomputed for that relationship. For \nnormal users, we can use the async \nfan-out and write posts into the \nprecomputed feed. For mega accounts \n(e.g. 100,000+ followers), we can \nskip precomputing.\n","version":540,"autoResize":true,"type":"text","backgroundColor":"#ffc9c9","index":"b44","roundness":null,"containerId":null,"originalText":"For very large accounts (hundreds of \nmillions of followers), pure fan-out \non write is not practical.\n\nSo we can use a hybrid approach:\nWe can add a flag in the follow table \nto indicate whether a feed should be \nprecomputed for that relationship. For \nnormal users, we can use the async \nfan-out and write posts into the \nprecomputed feed. For mega accounts \n(e.g. 100,000+ followers), we can \nskip precomputing.\n","height":350,"link":null,"strokeColor":"#1971c2","fillStyle":"cross-hatch","groupIds":[],"versionNonce":899177617,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[{"id":"8LlOGO2NgyfaBX3nOp0bP","type":"arrow"},{"id":"3M6Daz2jOh_Xt6o1nccML","type":"arrow"}],"x":4547.1213429834897,"angle":0,"y":4422.4894773410851,"width":384.6397705078125},{"seed":941924337,"strokeStyle":"solid","id":"V-4vyV9htZa0Nl6f4YyS6","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":20,"opacity":100,"verticalAlign":"top","updated":1776155981651,"locked":false,"text":"So, when a feed is requested, we:\n\n- Read precomputed feed entries for normal follows\n- Fetch recent posts on demand for mega accounts\n- Merge both results at runtime\n\nThis balances the system by reducing \nwrite amplification while still keeping \nreads fast.","version":582,"autoResize":false,"type":"text","backgroundColor":"#ffc9c9","index":"b45","roundness":null,"containerId":null,"originalText":"So, when a feed is requested, we:\n\n- Read precomputed feed entries for normal follows\n- Fetch recent posts on demand for mega accounts\n- Merge both results at runtime\n\nThis balances the system by reducing \nwrite amplification while still keeping \nreads fast.","height":225,"link":null,"strokeColor":"#1971c2","fillStyle":"cross-hatch","groupIds":[],"versionNonce":1147183729,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[{"id":"3M6Daz2jOh_Xt6o1nccML","type":"arrow"}],"x":5024.8834539659874,"angle":0,"y":4519.5262840497571,"width":509.63594715847995},{"seed":406384273,"strokeStyle":"solid","id":"8LlOGO2NgyfaBX3nOp0bP","strokeWidth":2,"roughness":1,"isDeleted":false,"startBinding":{"mode":"orbit","elementId":"bvOR_dOnwix9WmpD3YduV","fixedPoint":[-0.017120366956563233,0.49963636363636232]},"endArrowhead":"triangle","fixedSegments":null,"opacity":100,"startIsSpecial":null,"updated":1776155981651,"locked":false,"points":[[0,0],[-71.150282280534157,0],[-71.150282280534157,359.96523313826401],[-31.150282280534157,359.96523313826401]],"endIsSpecial":null,"version":204,"elbowed":true,"type":"arrow","backgroundColor":"#ffc9c9","index":"b46","roundness":null,"height":359.96523313826401,"link":null,"startArrowhead":null,"strokeColor":"#1971c2","fillStyle":"cross-hatch","groupIds":[],"endBinding":{"mode":"orbit","elementId":"py4insyjof3VzSdFvvGC3","fixedPoint":[-0.015599010970910853,0.49971428571428206]},"versionNonce":1105538129,"frameId":null,"boundElements":[],"x":4572.2716252640239,"angle":0,"y":4237.4242442028199,"width":71.150282280534157},{"seed":1678238847,"strokeStyle":"solid","id":"3M6Daz2jOh_Xt6o1nccML","strokeWidth":2,"roughness":1,"isDeleted":false,"startBinding":{"mode":"orbit","elementId":"py4insyjof3VzSdFvvGC3","fixedPoint":[1.0155990109709108,0.49971428571428206]},"endArrowhead":"triangle","fixedSegments":null,"opacity":100,"startIsSpecial":null,"updated":1776155981651,"locked":false,"points":[[0,0],[40.561170237343049,0],[40.561170237343049,34.536806708671975],[81.122340474686098,34.536806708671975]],"endIsSpecial":null,"version":147,"elbowed":true,"type":"arrow","backgroundColor":"#ffc9c9","index":"b47","roundness":null,"height":34.536806708671975,"link":null,"startArrowhead":null,"strokeColor":"#1971c2","fillStyle":"cross-hatch","groupIds":[],"endBinding":{"mode":"orbit","elementId":"V-4vyV9htZa0Nl6f4YyS6","fixedPoint":[-0.011773109870788213,0.49955555555554992]},"versionNonce":368933425,"frameId":null,"boundElements":[],"x":4937.7611134913022,"angle":0,"y":4597.3894773410839,"width":81.122340474686098},{"seed":1473873905,"strokeStyle":"solid","id":"GaPkpA3gQna0kJWyGlj6E","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":20,"opacity":100,"verticalAlign":"top","updated":1776156174222,"locked":false,"text":"Now lets say if a viral post (e.g. from \nTaylor Swift) is published, a huge number \nof users suddenly try to fetch the same \npost ID from DynamoDB. This creates a \nmassive spike on a single partition, even \nthough the rest of the system is fine. \nSince DynamoDB requires relatively even \nload across partitions, that one \noverloaded shard gets throttled while \nothers stay idle.","version":564,"autoResize":true,"type":"text","backgroundColor":"#ffc9c9","index":"b48","roundness":null,"containerId":null,"originalText":"Now lets say if a viral post (e.g. from \nTaylor Swift) is published, a huge number \nof users suddenly try to fetch the same \npost ID from DynamoDB. This creates a \nmassive spike on a single partition, even \nthough the rest of the system is fine. \nSince DynamoDB requires relatively even \nload across partitions, that one \noverloaded shard gets throttled while \nothers stay idle.","height":250,"link":null,"strokeColor":"#1e1e1e","fillStyle":"cross-hatch","groupIds":[],"versionNonce":1156228721,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[{"id":"3VYqH8kg6XoXNMjWBF16p","type":"arrow"}],"x":6374.3674453439426,"angle":0,"y":2178.173507350104,"width":408.979736328125},{"isDeleted":false,"locked":false,"strokeColor":"#1e1e1e","link":null,"roughness":1,"groupIds":[],"index":"b4A","backgroundColor":"#ffd43b","angle":0,"fillStyle":"solid","strokeWidth":2,"version":1524,"roundness":{"type":3},"type":"rectangle","updated":1776156174222,"id":"fcF8GN6yMBSKSYpW1ShIA","x":6332.4106098909333,"seed":1863000081,"boundElements":[],"y":2075.6372508657087,"opacity":100,"height":52.14340591569335,"width":479.20768206948378,"frameId":null,"strokeStyle":"solid","versionNonce":713994321},{"seed":1504638449,"strokeStyle":"solid","id":"qcxQjlcr7PoNJS45eMIMq","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":28,"opacity":100,"verticalAlign":"top","updated":1776156174222,"locked":false,"text":"Step Five: Adding a Cache Layer!","version":1448,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b4B","roundness":null,"containerId":null,"originalText":"Step Five: Adding a Cache Layer!","height":35,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":920026673,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":6346.5402430310087,"angle":0,"y":2082.6018013690891,"width":447.77581787109375},{"seed":1510923807,"strokeStyle":"solid","id":"1ORplLOnb7QfAR68Fcr9X","strokeWidth":2,"roughness":1,"isDeleted":false,"fontSize":20,"opacity":100,"verticalAlign":"top","updated":1776156174222,"locked":false,"text":"NOTE:\nThis is a classic\nhot key \/ hot \nshard problem","version":502,"autoResize":true,"type":"text","backgroundColor":"#ffc9c9","index":"b4C","roundness":null,"containerId":null,"originalText":"NOTE:\nThis is a classic\nhot key \/ hot \nshard problem","height":100,"link":null,"strokeColor":"#e03131","fillStyle":"cross-hatch","groupIds":[],"versionNonce":1755942929,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[{"id":"hmTv91zq8kbj7NUDazmWT","type":"arrow"},{"id":"3VYqH8kg6XoXNMjWBF16p","type":"arrow"}],"x":6883.3954754457072,"angle":0,"y":2161.6656175860508,"width":158.25985717773438},{"seed":1495017535,"strokeStyle":"solid","id":"hmTv91zq8kbj7NUDazmWT","strokeWidth":2,"roughness":1,"isDeleted":false,"startBinding":{"mode":"orbit","elementId":"Ngb3k8iJD8AOZbMyIm1Bw","fixedPoint":[1.0137165781144486,0.11215968567595262]},"endArrowhead":"triangle","fixedSegments":null,"opacity":100,"startIsSpecial":null,"updated":1776156174222,"locked":false,"points":[[0,0],[39.688532046649925,0],[39.688532046649925,-9.6610942516563227],[79.369877743163215,-9.6610942516563227]],"endIsSpecial":null,"version":521,"elbowed":true,"type":"arrow","backgroundColor":"#ffc9c9","index":"b4D","roundness":null,"height":9.6610942516563227,