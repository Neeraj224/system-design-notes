oundness":null,"containerId":null,"originalText":"score at some min \nx + 15","height":50,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":2134228694,"textAlign":"center","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1287.6634282481041,"angle":0,"y":2106.7299275368891,"width":181.61988830566406},{"seed":64710410,"strokeStyle":"solid","id":"IjYDYYtdxxVO0YlKqk5Ch","strokeWidth":2,"roughness":2,"isDeleted":false,"fontSize":20,"opacity":100,"verticalAlign":"top","updated":1776111039902,"locked":false,"text":"score at some min \nx + 20","version":216,"autoResize":true,"type":"text","backgroundColor":"#a5d8ff","index":"b8m","roundness":null,"containerId":null,"originalText":"score at some min \nx + 20","height":50,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":176619286,"textAlign":"center","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1094.0418245089666,"angle":0,"y":2107.808765350846,"width":181.61988830566406},{"seed":1008146646,"strokeStyle":"dashed","id":"Nitg4B0jNYbYbgOBJbBnh","strokeWidth":2,"roughness":2,"isDeleted":false,"fontSize":28,"opacity":100,"verticalAlign":"top","updated":1776112556589,"locked":false,"text":"Each event is going to be associated with a topic\nand each consumer group is going to be subscribed to a topic.\nThe soccer events will be consumed by the soccer consumer group\nand the basketball events will be consumed by the basketball \nconsumer group.","version":530,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b8n","roundness":null,"containerId":null,"originalText":"Each event is going to be associated with a topic\nand each consumer group is going to be subscribed to a topic.\nThe soccer events will be consumed by the soccer consumer group\nand the basketball events will be consumed by the basketball \nconsumer group.","height":175,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":743872662,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":488.05097789566798,"angle":0,"y":2300.8250787080565,"width":899.19183349609375},{"seed":53233942,"strokeStyle":"dashed","id":"MvfPRQPa6mW72pUTDZgug","strokeWidth":2,"roughness":2,"isDeleted":false,"fontSize":28,"opacity":100,"verticalAlign":"top","updated":1776113636876,"locked":false,"text":"In Kafka, a topic is a category\/stream of messages, \nand each topic is split into partitions.\nPartitions let Kafka distribute data across multiple servers \nfor scalability and parallel processing.\nEach partition is an ordered, append-only log, but ordering \nis only guaranteed within a partition, not across the whole topic.","version":555,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b8p","roundness":null,"containerId":null,"originalText":"In Kafka, a topic is a category\/stream of messages, \nand each topic is split into partitions.\nPartitions let Kafka distribute data across multiple servers \nfor scalability and parallel processing.\nEach partition is an ordered, append-only log, but ordering \nis only guaranteed within a partition, not across the whole topic.","height":210,"link":null,"strokeColor":"#1971c2","fillStyle":"solid","groupIds":[],"versionNonce":301235850,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[{"id":"0X6PcL9hQ_N1O13stogM7","type":"arrow"}],"x":465.85309754100376,"angle":0,"y":2792.7846430325571,"width":891.40765380859375},{"isDeleted":false,"locked":false,"strokeColor":"#868e96","link":null,"endArrowhead":"arrow","roughness":2,"groupIds":[],"startBinding":{"mode":"orbit","elementId":"u1Rp4nir_RBeB_TeffU3E","fixedPoint":[0,0.50009999999999999]},"index":"b8q","startArrowhead":null,"backgroundColor":"transparent","endBinding":null,"angle":0,"elbowed":false,"fillStyle":"solid","strokeWidth":2,"version":295,"roundness":{"type":2},"type":"arrow","updated":1776111614976,"id"