rue,"type":"text","backgroundColor":"#ffec99","index":"b99","roundness":null,"containerId":"kgkCMIq_LMhU8PMtDPeRd","originalText":"2","height":38.709677419354854,"link":null,"strokeColor":"#1e1e1e","fillStyle":"hachure","groupIds":[],"versionNonce":1675669590,"textAlign":"center","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":389.2511344433658,"angle":0,"y":2699.0907343346803,"width":21.6719970703125},{"seed":797227798,"strokeStyle":"solid","id":"5g-vBPPxwhfZDqfAwn6yC","strokeWidth":2,"roughness":2,"isDeleted":false,"fontSize":50.207957056393575,"opacity":100,"verticalAlign":"top","updated":1776113887620,"locked":false,"text":"Kafka - Basic Concepts and terminology","version":112,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b9A","roundness":null,"containerId":null,"originalText":"Kafka - Basic Concepts and terminology","height":62.75994632049197,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":1670879318,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":482.11154914836834,"angle":0,"y":2686.7458144245197,"width":972.12274169921875},{"isDeleted":false,"locked":false,"strokeColor":"#1e1e1e","link":null,"roughness":2,"groupIds":[],"index":"b9AV","backgroundColor":"#fff9db","angle":0,"fillStyle":"solid","strokeWidth":2,"version":76,"roundness":{"type":3},"type":"rectangle","updated":1776113846105,"id":"dyi5hf0vHoBgb_rLZrYBN","x":1579.3851001799605,"seed":1454651722,"boundElements":[],"y":3247.5281359219293,"opacity":100,"height":46.589974165081458,"width":176.69800395122297,"frameId":null,"strokeStyle":"solid","versionNonce":2039296906},{"seed":1351800150,"strokeStyle":"solid","id":"jOBE3bgAQwVYFC3_Gpyvh","strokeWidth":2,"roughness":2,"isDeleted":false,"fontSize":36,"opacity":100,"verticalAlign":"top","updated":1776113772486,"locked":false,"text":"The controller in Kafka is a special broker \nthat coordinates the cluster.\n\nIts main responsibilities are:\n- Keeps track of which brokers are alive or down\n- Manages partition leadership (choosing a leader \n  broker for each partition)\n- Handles leader election when a broker fails\n- Triggers reassignments of partitions to maintain \n  availability\n- Maintains cluster metadata consistency\n\nSo:\nBrokers store data and the Controller manages the \ncluster state and decides who is responsible for what","version":57,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b9B","roundness":null,"containerId":null,"originalText":"The controller in Kafka is a special broker \nthat coordinates the cluster.\n\nIts main responsibilities are:\n- Keeps track of which brokers are alive or down\n- Manages partition leadership (choosing a leader \n  broker for each partition)\n- Handles leader election when a broker fails\n- Triggers reassignments of partitions to maintain \n  availability\n- Maintains cluster metadata consistency\n\nSo:\nBrokers store data and the Controller manages the \ncluster state and decides who is responsible for what","height":675,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":1529347542,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1497.789722341487,"angle":0,"y":3248.4430989243892,"width":948.59967041015625},{"isDeleted":false,"locked":false,"strokeColor":"transparent","link":null,"status":"saved","roughness":2,"groupIds":[],"index":"b9D","backgroundColor":"#fff9db","fileId":"24f2d7bf051be12b2c7a0810e391e2488daba8d2","angle":0,"fillStyle":"solid","crop":null,"strokeWidth":2,"version":184,"roundness":null,"type":"image","updated":1776114021505,"id":"e-ntklX5iAcwazfF_Hvbq","x":398.44603789755456,"seed":1907354378,"boundElements":[],"y":4042.6104373874332,"opacity":100,"height":1116.8381196846326,"scale":[1,1],"width":2403.9564908010029,"frameId":null,"strokeStyle":"solid","versionNonce":1304346314},{"isDeleted":false,"locked":false,"strokeColor"