int":[0,0.50009999999999999]},"index":"b8t","startArrowhead":null,"backgroundColor":"transparent","endBinding":null,"angle":0,"elbowed":false,"fillStyle":"solid","strokeWidth":2,"version":128,"roundness":{"type":2},"type":"arrow","updated":1776111607287,"id":"HRKxLcu3H5jLWLgVt_-9H","x":910.91182127182867,"seed":642476630,"boundElements":[],"y":1697.2589854350747,"opacity":100,"height":757.45763156365274,"points":[[0,0],[-152.30130478116064,-757.45763156365274]],"width":152.30130478116064,"frameId":null,"strokeStyle":"dashed","versionNonce":1599266582},{"isDeleted":false,"locked":false,"strokeColor":"#868e96","link":null,"endArrowhead":"arrow","roughness":2,"groupIds":[],"startBinding":{"mode":"orbit","elementId":"hNUJZoc65jEg2F1I1kE4k","fixedPoint":[0,0.50009999999999999]},"index":"b8u","startArrowhead":null,"backgroundColor":"transparent","endBinding":null,"angle":0,"elbowed":false,"fillStyle":"solid","strokeWidth":2,"version":244,"roundness":{"type":2},"type":"arrow","updated":1776111617557,"id":"n30FJpNnKUQJINJb26_ud","x":914.59156561353234,"seed":1287002506,"boundElements":[],"y":1880.6911860016614,"opacity":100,"height":938.05081401449286,"points":[[0,0],[-178.15912133399252,-938.05081401449286]],"width":178.15912133399252,"frameId":null,"strokeStyle":"dashed","versionNonce":1170792406},{"isDeleted":false,"locked":false,"strokeColor":"#868e96","link":null,"endArrowhead":"arrow","roughness":2,"groupIds":[],"startBinding":{"mode":"orbit","elementId":"XNRiqnRGIK4ipbXcpVwgZ","fixedPoint":[0,0.50009999999999999]},"index":"b8v","startArrowhead":null,"backgroundColor":"transparent","endBinding":null,"angle":0,"elbowed":false,"fillStyle":"solid","strokeWidth":2,"version":138,"roundness":{"type":2},"type":"arrow","updated":1776111600897,"id":"56D0V3cIQFLoZhbmi5rhP","x":914.40377717048364,"seed":2046882518,"boundElements":[],"y":2057.5573592932847,"opacity":100,"height":1117.0392236203622,"points":[[0,0],[-197.14875971736024,-1117.0392236203622]],"width":197.14875971736024,"frameId":null,"strokeStyle":"dashed","versionNonce":1370866838},{"seed":1773447062,"strokeStyle":"dashed","id":"wIBP-GNI-UhauFmkI5cj8","strokeWidth":2,"roughness":2,"isDeleted":false,"fontSize":28,"opacity":100,"verticalAlign":"top","updated":1776111629676,"locked":false,"text":"Partitions","version":38,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b8w","roundness":null,"containerId":null,"originalText":"Partitions","height":35,"link":null,"strokeColor":"#868e96","fillStyle":"solid","groupIds":[],"versionNonce":1313096714,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":671.34677267545464,"angle":0,"y":886.77880676232644,"width":138.29191589355469},{"isDeleted":false,"locked":false,"strokeColor":"#1e1e1e","link":null,"roughness":2,"groupIds":[],"index":"b8x","backgroundColor":"transparent","angle":0,"fillStyle":"solid","strokeWidth":2,"version":277,"roundness":{"type":3},"type":"rectangle","updated":1776113517265,"id":"T6eEZMS0ngBbEHdwrSNpt","x":391.34177864523235,"seed":1238867658,"boundElements":[],"y":684.19013499264099,"opacity":100,"height":1809.126091035954,"width":2329.1341419825362,"frameId":null,"strokeStyle":"dashed","versionNonce":629156874},{"seed":1751642762,"strokeStyle":"dashed","id":"CI2J8yTG_7VczNh5jFXcZ","strokeWidth":2,"roughness":2,"isDeleted":false,"fontSize":28,"opacity":100,"verticalAlign":"top","updated":1776113791695,"locked":false,"text":"Terminology:\n* Broker: A server (physical\/virtual) that holds the \"queue\"\n   - i.e. stores data and serves client requests.\n* Topic: A named logical grouping of partitions (it exists in code). \n    We publish to and consume from topics in Kafka\n* Partition: The \"queue\" - an ordered immutable sequence of messages \n    that we append to, like a log file. each broker can have multiple \n    partitions.\n* Producer: Sends (writes) messages to topics.\n* Consumer: Reads messages from topics.\n","version":951,"autoResize":true,"type":"text","backgroundColor":"transparent","index":"b8y","roundness":null,"containerId":null,"originalText":"Terminology:\n* Broker: A server (physical\/virtual) that holds the \"queue\"\n   - i.e. stores data and serves client requests.\n* Topic: A named logical grouping of partitions (it exists in code). \n    We publish to and consume from topics in Kafka\n* Partition: The \"queue\" - an ordered immutable sequence of messages \n    that we append to, like a log file. each broker can have multiple \n    partitions.\n* Producer: Sends (writes) messages to topics.\n* Consumer: Reads messages from topics.\n","height":385,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":1047260362,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":1476.5891214631774,"angle":0,"y":2797.3530655244135,"width":968.1556396484375},{"seed":1355040714,"strokeStyle":"dashed","id":"7aQcBfLdnk4_QML0YW0eG","strokeWidth":2,"roughness":2,"isDeleted":false,"fontSize":27.504681101817706,"opacity":100,"verticalAlign":"top","updated":1776113636876,"locked":false,"text":"In Apache Kafka, brokers store partitions, not whole topics. \nA topic is logical, and its partitions are distributed across\nmultiple brokers. \nEach broker holds some partitions of one or more topics.\n","version":914,"autoResize":false,"type":"text","backgroundColor":"transparent","index":"b90","roundness":null,"containerId":null,"originalText":"In Apache Kafka, brokers store partitions, not whole topics. \nA topic is logical, and its partitions are distributed across multiple brokers. \nEach broker holds some partitions of one or more topics.\n","height":171.90425688636066,"link":null,"strokeColor":"#1971c2","fillStyle":"solid","groupIds":[],"versionNonce":1796858890,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":520.15239874084682,"angle":0,"y":3136.7980263116456,"width":830.8876141492176},{"seed":21664458,"strokeStyle":"dashed","id":"SZiEvUpQ2pa2ZhjYeic0f","strokeWidth":2,"roughness":2,"isDeleted":false,"fontSize":28,"opacity":100,"verticalAlign":"top","updated":1776113636876,"locked":false,"text":"Topics are a way of organizing\nthe data, while partitions are a \nway of scaling the data","version":1349,"autoResize":true,"type":"text","backgroundColor":"#fff9db","index":"b91","roundness":null,"containerId":null,"originalText":"Topics are a way of organizing\nthe data, while partitions are a \nway of scaling the data","height":105,"link":null,"strokeColor":"#e03131","fillStyle":"solid","groupIds":[],"versionNonce":588567242,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":507.41457516579294,"angle":0,"y":3336.0955221131549,"width":442.091796875},{"seed":1517103498,"strokeStyle":"dashed","id":"AAFvf_mKkDbTX2G4iOm99","strokeWidth":2,"roughness":2,"isDeleted":false,"fontSize":28,"opacity":100,"verticalAlign":"top","updated":1776113636876,"locked":false,"text":"Why partition keys are needed:\nA partition key decides which partition a message goes to. \nThis helps keep related messages in order (same key goes \nto same partition) and also distributes load across multiple \nbrokers.\n\nWhy offsets are needed:\nAn offset is the sequence number of a message inside a \npartition. It lets consumers track progress, resume \nafter failure, and replay data if needed.","version":430,"autoResize":true,"type":"text","backgroundColor":"#e6fcf5","index":"b92","roundness":null,"containerId":null,"originalText":"Why partition keys are needed:\nA partition key decides which partition a message goes to. \nThis helps keep related messages in order (same key goes \nto same partition) and also distributes load across multiple \nbrokers.\n\nWhy offsets are needed:\nAn offset is the sequence number of a message inside a \npartition. It lets consumers track progress, resume \nafter failure, and replay data if needed.","height":350,"link":null,"strokeColor":"#1e1e1e","fillStyle":"solid","groupIds":[],"versionNonce":1665395082,"textAlign":"left","fontFamily":5,"lineHeight":1.25,"frameId":null,"boundElements":[],"x":509.02317571980291,"angle":0,"y":3500.0781872535135,"width":825.24359130859375},{"isDeleted":false,"locked":false,"strokeColor":"#1e1e1e","link":null,"roughness":2,"groupIds":[],"index":"b93","backgroundColor":"transparent","angle":0,"fillStyle":"solid","strokeWidth":2,"version":307,"roundness":{"type":3},"type":"rectangle","updated":1776113636876,"id":"yuQ3IaI9EmkqhvxkcZa79","x":409.43722215714115,"seed":2005519754,"boundElements":[],"y":2756.393521981563,"opacity":100,"height":1239.8420798961295,"width":2094.8123090138884,"frameId":null,"strokeStyle":"dashed","versionNonce":1658988618},{"isDeleted":false,"locked":false,"strokeColor":"#1e1e1e","link":null,"roughness":2,"groupIds":[],"index":"b94","backgroundColor":"transparent","angle":0,"fillStyle":"solid","strokeWidth":2,"version":292,"roundness":{"type":3},"type":"rectangle","updated":1776113636876,"id":"y5HahKCID4rIdMt6rLAwD","x":481.02627578407396,"seed":800583702,"boundElements":[{"id":"0X6PcL9hQ_N1O13stogM7","type":"arrow"}],"y":3093.0782653880333,"opacity":100,"height":820.78945297643259,"width":908.43404503665602,"frameId":null,"strokeStyle":"solid","versionNonce":969576202},{"isDeleted":false,"locked":false,"strokeColor":"#1e1e1e","link":null,"roughness":2,"groupIds":[],"index":"b95","backgroundColor":"transparent","angle":0,"fillStyle":"solid","strokeWidth":2,"version":198,"roundness":{"type":3},"type":"rectangle","updated":1776113636876,"id":"CekMRkX-UE5kx5a_Lk7PY","x":1457.0124362583097,"seed":1029140246,"boundElements":[],"y":2779.3753807600383,"opacity":100,"height":389.03174139988732,"width":1003.9168546472742,"frameId":null,"strokeStyle":"solid","versionNonce":1282940362},{"isDeleted":false,"locked":false,"strokeColor":"#1e1e1e","link":null,"endArrowhead":"arrow","roughness":2,"groupIds":[],"startBinding":{"mode":"orbit","elementId":"MvfPRQPa6mW72p