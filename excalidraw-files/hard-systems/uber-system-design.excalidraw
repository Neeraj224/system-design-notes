      "isDeleted": false,
      "boundElements": [
        {
          "id": "DY2jBxCJP0gsOBGCqkBJs",
          "type": "arrow"
        }
      ],
      "updated": 1776231118346,
      "link": null,
      "locked": false,
      "text": "To be super explicit\nabout the flow of data:\nthe writer sends a\nrequest to get a fair\nestimate.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "To be super explicit about the flow of data:\nthe writer sends a request to get a fair estimate.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "xIpqeayudj7dWIXIsEQLu",
      "type": "text",
      "x": 4013.322460682475,
      "y": 10272.872522537617,
      "width": 349.96940539765137,
      "height": 270,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "dotted",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b3d",
      "roundness": null,
      "seed": 1008045271,
      "version": 1065,
      "versionNonce": 531024567,
      "isDeleted": false,
      "boundElements": [
        {
          "id": "DY2jBxCJP0gsOBGCqkBJs",
          "type": "arrow"
        },
        {
          "id": "y8cMri5_ixb-DGKo7LkrW",
          "type": "arrow"
        }
      ],
      "updated": 1776231118346,
      "link": null,
      "locked": false,
      "text": "We calculate the\nestimate and\npersist it in our DB\nwith fields like fare\nand ETA.\n",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "We calculate the estimate and persist it in our DB\nwith fields like fare and ETA.\n",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "nrhJm7AiVo1SIj8eT2uH9",
      "type": "text",
      "x": 4023.147776436777,
      "y": 10690.530040534039,
      "width": 390.7154148544242,
      "height": 180,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "dotted",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b3e",
      "roundness": null,
      "seed": 1571423703,
      "version": 1129,
      "versionNonce": 722051129,
      "isDeleted": false,
      "boundElements": [
        {
          "id": "y8cMri5_ixb-DGKo7LkrW",
          "type": "arrow"
        }
      ],
      "updated": 1776231118346,
      "link": null,
      "locked": false,
      "text": "Finally, we return to\nthe user the ride ID,\nthe fare, and the\nETA.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Finally, we return to the user the ride ID,\nthe fare, and the ETA.",
      "autoResize": false,
      "lineHeight": 1.25
    },
