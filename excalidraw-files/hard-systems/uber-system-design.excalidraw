      "seed": 1348431191,
      "version": 605,
      "versionNonce": 221614745,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1776229913065,
      "link": null,
      "locked": false,
      "text": "To be super explicit\nabout the flow of data:\nthe writer sends a\nrequest to get a fair\nestimate.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "To be super explicit about the flow of data:\nthe writer sends a request to get a fair estimate.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "GxL7haSzVBsC1bpjDTOFN",
      "type": "text",
      "x": 3877.1869689016307,
      "y": 13142.607111218396,
      "width": 349.96940539765137,
      "height": 270,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "dotted",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b4S",
      "roundness": null,
      "seed": 2127932023,
      "version": 1024,
      "versionNonce": 259005433,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1776229910569,
      "link": null,
      "locked": false,
      "text": "We calculate the\nestimate and\npersist it in our DB\nwith fields like fare\nand ETA.\n",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "We calculate the estimate and persist it in our DB\nwith fields like fare and ETA.\n",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "JhKg745IQj-O5z0N1OwMP",
      "type": "text",
      "x": 3887.012284655933,
      "y": 13560.26462921482,
      "width": 390.7154148544242,
      "height": 180,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "dotted",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b4T",
      "roundness": null,
      "seed": 969360279,
      "version": 1086,
      "versionNonce": 1133289593,
      "isDeleted": true,
      "boundElements": [
        {
          "id": "XUsDlf8cQUpZwllLabh_Z",
          "type": "arrow"
        }
      ],
      "updated": 1776229909834,
      "link": null,
      "locked": false,
      "text": "Finally, we return to\nthe user the ride ID,\nthe fare, and the\nETA.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Finally, we return to the user the ride ID,\nthe fare, and the ETA.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "KKpPcbH_he9bEZ43eWKL6",
      "type": "arrow",
      "x": 3612.467699909869,
