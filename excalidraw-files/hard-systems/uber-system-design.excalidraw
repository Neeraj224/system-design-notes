      "isDeleted": true,
      "boundElements": [],
      "updated": 1776231400466,
      "link": null,
      "locked": false,
      "text": "The first thing this service\nneeds is driver location data.\nWe will use a location\ndatabase that stores the\ncurrent position of all drivers.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The first thing this service needs is driver location data.\nWe will use a location database that stores the current position of all drivers.",
      "autoResize": false,
      "lineHeight": 1.25
    },
