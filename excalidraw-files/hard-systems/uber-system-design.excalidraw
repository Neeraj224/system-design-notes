    {
      "id": "DtaCER4_xCx3p0e7zSI5R",
      "type": "text",
      "x": 1660.5376046348351,
      "y": 6676.338380686126,
      "width": 889.271728515625,
      "height": 135,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0U",
      "roundness": null,
      "seed": 157440663,
      "version": 175,
      "versionNonce": 1257700313,
      "isDeleted": false,
      "boundElements": [
        {
          "id": "VU4FiUrqdLVxFTFCJN3n5",
          "type": "arrow"
        }
      ],
      "updated": 1776222039552,
      "link": null,
      "locked": false,
      "text": "4. Now, drivers need the ability to accept or deny \na ride request, and then navigate to pickup\nand drop-off.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "4. Now, drivers need the ability to accept or deny \na ride request, and then navigate to pickup\nand drop-off.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "IBfwZ5VAXJmSZ9VTJaS66",
      "type": "text",
      "x": 2614.058442401341,
      "y": 6672.58060131311,
      "width": 518.2918701171875,
      "height": 360,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0V",
      "roundness": null,
      "seed": 882374743,
      "version": 176,
      "versionNonce": 574363833,
      "isDeleted": false,
      "boundElements": [
        {
          "id": "VU4FiUrqdLVxFTFCJN3n5",
          "type": "arrow"
        }
      ],
      "updated": 1776222039552,
      "link": null,
      "locked": false,
      "text": "This can be handled via the\nride API, where the driver\nsends the ride ID along with\na true/false to accept or\ndeny the match.\nSo given a ride ID, the driver\nchooses whether to accept\nor reject the request.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "This can be handled via the\nride API, where the driver\nsends the ride ID along with\na true/false to accept or\ndeny the match.\nSo given a ride ID, the driver\nchooses whether to accept\nor reject the request.",
      "autoResize": true,
      "lineHeight": 1.25
    },
