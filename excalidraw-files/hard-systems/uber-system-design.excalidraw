        }
      ],
      "updated": 1776222039552,
      "link": null,
      "locked": false,
      "text": "Since matching is asynchronous\nand can take up to a minute,\nthe request returns immediately\nwith a status (e.g. 200 or 400).\nThe actual driver matching\nhappens in the background\nafter the request is accepted.\n",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Since matching is asynchronous\nand can take up to a minute,\nthe request returns immediately\nwith a status (e.g. 200 or 400).\nThe actual driver matching\nhappens in the background\nafter the request is accepted.\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
