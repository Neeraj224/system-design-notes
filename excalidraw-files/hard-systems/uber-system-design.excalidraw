      "seed": 1062364087,
      "version": 177,
      "versionNonce": 1532182007,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1776226363389,
      "link": null,
      "locked": false,
      "text": "1. To get an estimate of the ride/fare, from the\nsource to the destination:",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. To get an estimate of the ride/fare, from the\nsource to the destination:",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "HhlUL5Inpn5JJQDp9lmCi",
      "type": "text",
      "x": 3086.9236077598734,
      "y": 4643.1142745011075,
      "width": 525.203857421875,
      "height": 315,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#fff0f6",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b03",
      "roundness": null,
      "seed": 846548857,
      "version": 269,
      "versionNonce": 2095422969,
      "isDeleted": false,
      "boundElements": [
        {
          "id": "u8GE_Aqc833jUeszn96Lj",
          "type": "arrow"
        }
      ],
      "updated": 1776222039552,
      "link": null,
      "locked": false,
      "text": "Instead of a separate entity,\nwe include these fields in the\nride entity itself.\nThis ride entity can then be\nupdated later if the user\nconfirms the ride and we\nproceed to matching.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Instead of a separate entity,\nwe include these fields in the\nride entity itself.\nThis ride entity can then be\nupdated later if the user\nconfirms the ride and we\nproceed to matching.",
      "autoResize": true,
      "lineHeight": 1.25
    },
