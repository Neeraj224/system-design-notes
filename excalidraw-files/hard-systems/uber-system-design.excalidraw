        }
      ],
      "updated": 1776222039552,
      "link": null,
      "locked": false,
      "text": "we'll use PATCH here because \nwe are updating the same ride \nrecord.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "we'll use PATCH here because \nwe are updating the same ride \nrecord.",
      "autoResize": true,
