    {
      "id": "BiWM3R0Y57Qu_zmawDDk9",
      "type": "text",
      "x": 1865.8368039381323,
      "y": 15501.045227018043,
      "width": 446.84132220667624,
      "height": 180,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b6N",
      "roundness": null,
      "seed": 1194957175,
      "version": 175,
      "versionNonce": 1029116535,
      "isDeleted": false,
      "boundElements": [
        {
          "id": "RTQi8Hza7BBh2gOCOBVwK",
          "type": "arrow"
        }
      ],
      "updated": 1776232221753,
      "link": null,
      "locked": false,
      "text": "So now, drivers would\nhave their own client app\nthat sends periodic\nlocation updates.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "So now, drivers would have their own client app\nthat sends periodic location updates.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "bHivZJkAYhrjkcwz4U6Uh",
      "type": "text",
      "x": 1845.4071350126637,
      "y": 15770.652930982733,
      "width": 573.1141672144424,
      "height": 225,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b6O",
      "roundness": null,
      "seed": 286350681,
      "version": 474,
      "versionNonce": 325654775,
      "isDeleted": false,
      "boundElements": [
        {
          "id": "RTQi8Hza7BBh2gOCOBVwK",
          "type": "arrow"
        },
        {
          "id": "7V6JUvjw81KkP-TPKIX-c",
          "type": "arrow"
        }
      ],
      "updated": 1776232223003,
      "link": null,
      "locked": false,
      "text": "We would have a location service\nthat receives these updates\nand stores them in the location\ndatabase for the ride matching\nservice to query.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "We would have a location service\nthat receives these updates and stores them in the location database for the ride matching service to query.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "S1U7R3PQ--F-YYnNrCu8S",
      "type": "text",
      "x": 1869.986017269152,
      "y": 16181.350632495021,
      "width": 507.9595102934252,
      "height": 225,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b6P",
      "roundness": null,
      "seed": 927708249,
      "version": 626,
      "versionNonce": 666995767,
      "isDeleted": false,
      "boundElements": [
        {
          "id": "7V6JUvjw81KkP-TPKIX-c",
          "type": "arrow"
        },
        {
          "id": "v_UfouNMuuLOMtop_eZ11",
          "type": "arrow"
        }
      ],
      "updated": 1776233424724,
      "link": null,
      "locked": false,
      "text": "We would need to add that\ndata to the database so\nthe matching service can\nfind nearby drivers and filter\nthem based on status.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "We would need to add that data to the database so the matching service can find nearby drivers and filter them based on status.",
      "autoResize": false,
      "lineHeight": 1.25
    },
