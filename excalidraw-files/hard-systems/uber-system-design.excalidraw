      "text": "Rider\niOS/Android\n(Client App)",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "SISHQVNLhMkAiZlPbqwje",
      "originalText": "Rider\niOS/Android\n(Client App)",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "VRvrwLZuy5hQl-SoOiS2W",
      "type": "text",
      "x": 1824.4715869198585,
      "y": 8989.405757109496,
      "width": 642.4917602539062,
      "height": 135,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1P",
      "roundness": null,
      "seed": 1049384601,
      "version": 408,
      "versionNonce": 1770203641,
      "isDeleted": false,
      "boundElements": [
        {
          "id": "rdsgXAb00o8TmhoLVTT9N",
          "type": "arrow"
        }
      ],
      "updated": 1776228369106,
      "link": null,
      "locked": false,
      "text": "To support ride requests, we \nneed a client application for the \nrider, such as an iOS or Android app.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "To support ride requests, we \nneed a client application for the \nrider, such as an iOS or Android app.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "1XIgXGszZUUNQBr0XqVTE",
      "type": "text",
      "x": 2584.907726325842,
      "y": 8597.838464925087,
      "width": 607.6798095703125,
      "height": 450,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1V",
      "roundness": null,
      "seed": 658644729,
      "version": 727,
      "versionNonce": 392004313,
      "isDeleted": false,
      "boundElements": [
        {
          "id": "rdsgXAb00o8TmhoLVTT9N",
          "type": "arrow"
        },
        {
          "id": "38sIDUuTyVamkG9v5pxto",
          "type": "arrow"
        }
      ],
      "updated": 1776228369106,
      "link": null,
      "locked": false,
      "text": "The rider sends a request\nthat first hits AWS API Gateway,\nwhich handles load balancing\nand routing.\n\nAPI Gateway forwards requests\nto the correct microservice\nand also handles tasks like\nauthentication, SSL termination,\nand rate limiting.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The rider sends a request\nthat first hits AWS API Gateway,\nwhich handles load balancing\nand routing.\n\nAPI Gateway forwards requests\nto the correct microservice\nand also handles tasks like\nauthentication, SSL termination,\nand rate limiting.",
      "autoResize": true,
      "lineHeight": 1.25
    },
