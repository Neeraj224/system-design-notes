    {
      "id": "3LnUDsrqiAvblo6V-OJSq",
      "type": "text",
      "x": 3183.059724060917,
      "y": 6804.937086842197,
      "width": 517.2838134765625,
      "height": 315,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0b",
      "roundness": null,
      "seed": 572862073,
      "version": 355,
      "versionNonce": 475691513,
      "isDeleted": false,
      "boundElements": [
        {
          "id": "hQJr7doyPJ7efDcBnvZN3",
          "type": "arrow"
        }
      ],
      "updated": 1776222039552,
      "link": null,
      "locked": false,
      "text": "In practice, this could also \nbe a POST if we model it \nas creating a new status\nentry or event. But for now, \nPATCH is sufficient since\nwe are just updating the \nexisting ride state.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "In practice, this could also \nbe a POST if we model it \nas creating a new status\nentry or event. But for now, \nPATCH is sufficient since\nwe are just updating the \nexisting ride state.",
      "autoResize": true,
      "lineHeight": 1.25
    },
