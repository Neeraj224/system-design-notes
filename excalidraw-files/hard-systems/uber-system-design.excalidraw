      "roundness": null,
      "seed": 1200464953,
      "version": 50,
      "versionNonce": 1153008281,
      "isDeleted": false,
      "boundElements": [
        {
          "id": "dxWxhbnCVzJQeHuELO5sB",
          "type": "arrow"
        }
      ],
      "updated": 1776222039552,
      "link": null,
      "locked": false,
      "text": "3. The matching process requires real-time \nknowledge of driver locations. We need this \ndata to find nearby drivers and match them \nefficiently to the ride: \n",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "3. The matching process requires real-time \nknowledge of driver locations. We need this \ndata to find nearby drivers and match them \nefficiently to the ride: \n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "4pVQBzSMNMw83kQh_ggtd",
      "type": "text",
      "x": 2529.522334087351,
      "y": 6056.205400432464,
      "width": 582.4078369140625,
      "height": 315,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0P",
      "roundness": null,
      "seed": 473572537,
      "version": 161,
      "versionNonce": 931121017,
      "isDeleted": false,
      "boundElements": [
        {
          "id": "dxWxhbnCVzJQeHuELO5sB",
          "type": "arrow"
        }
      ],
      "updated": 1776222039552,
      "link": null,
      "locked": false,
      "text": "We track driver locations\nusing a location update endpoint.\nDrivers periodically call this\nendpoint every few seconds\nto send their latest location.\nThis keeps the system updated\nwith real-time driver positions.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "We track driver locations\nusing a location update endpoint.\nDrivers periodically call this\nendpoint every few seconds\nto send their latest location.\nThis keeps the system updated\nwith real-time driver positions.",
      "autoResize": true,
      "lineHeight": 1.25
    },
