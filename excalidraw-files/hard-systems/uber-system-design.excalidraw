    {
      "id": "6qhbSxWTz17-BAIJJClpo",
      "type": "text",
      "x": 3231.2952976093115,
      "y": 8595.911337784048,
      "width": 389.05516420074235,
      "height": 617.6951577002288,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1Z",
      "roundness": null,
      "seed": 990290521,
      "version": 1369,
      "versionNonce": 2132141433,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1776228369106,
      "link": null,
      "locked": false,
      "text": "Load balancing is\ndistributing traffic\nacross multiple servers.\nRouting is\nsending requests\nto the correct service.\nRate limiting is\ncontrolling how many\nrequests a user can make.\nAuthentication is\nverifying user identity\nbefore allowing access.\nSSL termination is\ndecrypting HTTPS traffic\nat the gateway before\nforwarding it internally.",
      "fontSize": 30.884757885011442,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Load balancing is\ndistributing traffic\nacross multiple servers.\nRouting is\nsending requests\nto the correct service.\nRate limiting is\ncontrolling how many\nrequests a user can make.\nAuthentication is\nverifying user identity\nbefore allowing access.\nSSL termination is\ndecrypting HTTPS traffic\nat the gateway before\nforwarding it internally.",
      "autoResize": true,
      "lineHeight": 1.25
    },
