      "type": "text",
      "x": 1646.2563915615572,
      "y": 4541.882402628317,
      "width": 858.3116455078125,
      "height": 90,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#fff0f6",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 2,
