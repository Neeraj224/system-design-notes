    },
    {
      "id": "2ba3NNLeE5QnskSJXL44r",
      "type": "text",
      "x": 1947.9646394232377,
      "y": 3885.284470020652,
      "width": 761.687744140625,
      "height": 270,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aj",
      "roundness": null,
      "seed": 766715191,
      "version": 261,
      "versionNonce": 1656545239,
      "isDeleted": false,
      "boundElements": [
        {
          "id": "8orUtDGQuCvtqWT7V3UQ3",
          "type": "arrow"
        }
      ],
      "updated": 1776217073224,
      "link": null,
      "locked": false,
      "text": "A location entity to store the real-time\nlocation of all drivers. Need to keep \nthis data continuously updated\nso the system can quickly find nearby\ndrivers and match them based on proximity.\n",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "A location entity to store the real-time\nlocation of all drivers. Need to keep \nthis data continuously updated\nso the system can quickly find nearby\ndrivers and match them based on proximity.\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
