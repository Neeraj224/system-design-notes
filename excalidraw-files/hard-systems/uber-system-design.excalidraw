    {
      "id": "sOVV76y704aijUTcSe629",
      "type": "text",
      "x": 2504.7825468686683,
      "y": 9334.024967893296,
      "width": 477.86383056640625,
      "height": 135,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1o",
      "roundness": null,
      "seed": 1984862423,
      "version": 648,
      "versionNonce": 799674937,
      "isDeleted": false,
      "boundElements": [
        {
          "id": "38sIDUuTyVamkG9v5pxto",
          "type": "arrow"
        }
      ],
      "updated": 1776228369106,
      "link": null,
      "locked": false,
      "text": "Actually Uber uses\na complex ML model\nto estimate ETA and price.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Actually Uber uses\na complex ML model\nto estimate ETA and price.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "nohDmxHMlSW2ce4tBiWrN",
      "type": "text",
      "x": 2512.2146465027795,
      "y": 9484.355674338554,
      "width": 531.4317626953125,
      "height": 180,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1p",
      "roundness": null,
      "seed": 777975255,
      "version": 644,
      "versionNonce": 16605977,
      "isDeleted": false,
      "boundElements": [
        {
          "id": "nGuEvZndy-6Rd091T--te",
          "type": "arrow"
        }
      ],
      "updated": 1776228369106,
      "link": null,
      "locked": false,
      "text": "For our interview, we will use\na third-party mapping API\nlike Google Maps instead - for\nthe sake of simplicity.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "For our interview, we will use\na third-party mapping API\nlike Google Maps instead - for\nthe sake of simplicity.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "F5SLnu7ySIHOQmB2xDadp",
      "type": "text",
      "x": 3258.8226392506235,
      "y": 9256.596575133664,
      "width": 577.9797973632812,
      "height": 180,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1u",
      "roundness": null,
      "seed": 543551703,
      "version": 864,
      "versionNonce": 1903400953,
      "isDeleted": false,
      "boundElements": [
        {
          "id": "AlPMzfSTVGptiZZlCEzh2",
          "type": "arrow"
        },
        {
          "id": "nGuEvZndy-6Rd091T--te",
          "type": "arrow"
        }
      ],
      "updated": 1776228369106,
      "link": null,
      "locked": false,
      "text": "It takes source and destination,\nand returns an ETA/estimate to\nget from the source to the\ndestination",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "It takes source and destination,\nand returns an ETA/estimate to\nget from the source to the\ndestination",
      "autoResize": true,
      "lineHeight": 1.25
    },
