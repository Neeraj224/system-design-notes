    {
      "id": "HMe03RtYBmujr9ZT_pxjw",
      "type": "text",
      "x": 3510.5026250985734,
      "y": 18013.790789093997,
      "width": 524.3542869366238,
      "height": 450,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b6W",
      "roundness": null,
      "seed": 1779157273,
      "version": 775,
      "versionNonce": 2087985111,
      "isDeleted": false,
      "boundElements": [
        {
          "id": "Tu8KBCknmEgQUy16AnSGV",
          "type": "arrow"
        },
        {
          "id": "q55B6gXs42yPwvhraHv-x",
          "type": "arrow"
        }
      ],
      "updated": 1776233505117,
      "link": null,
      "locked": false,
      "text": "Once eligible drivers are\nfound, the system sends\nride requests to them\nthrough a notification\nservice.\nWe abstract this as a\nnotification service using\npush notifications (APNs -\nApple Push Notifications for\niOS, Firebase for Android).",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Once eligible drivers are found, the system sends\nride requests to them through a notification service.\nWe abstract this as a notification service using\npush notifications (APNs - Apple Push Notifications for iOS, Firebase for Android).",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "F2uitC3LXlyBDvnUYf4S8",
      "type": "text",
      "x": 3358.1367069126172,
      "y": 15095.286845760134,
      "width": 764.8916625976562,
      "height": 90,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b6X",
      "roundness": null,
      "seed": 995490617,
      "version": 3,
      "versionNonce": 166093719,
      "isDeleted": true,
      "boundElements": null,
      "updated": 1776232355891,
      "link": null,
      "locked": false,
      "text": "Drivers receive the request and respond via\nan API call",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Drivers receive the request and respond via an API call",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "CbcbsAp1neNSEVRDga1ln",
      "type": "text",
      "x": 3482.606616580586,
      "y": 15217.786845760134,
      "width": 515.9518432617188,
      "height": 45,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b6Y",
      "roundness": null,
      "seed": 1233465559,
      "version": 3,
      "versionNonce": 953451865,
      "isDeleted": true,
      "boundElements": null,
      "updated": 1776232355891,
      "link": null,
      "locked": false,
      "text": "to the accept/deny endpoint.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "to the accept/deny endpoint.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "_St1Sektsr5fC2WA8ZLGB",
      "type": "text",
      "x": 3347.480670535664,
      "y": 15250.286845760134,
      "width": 786.2037353515625,
      "height": 90,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b6Z",
      "roundness": null,
      "seed": 1631857689,
      "version": 3,
      "versionNonce": 1352915127,
      "isDeleted": true,
      "boundElements": null,
      "updated": 1776232355891,
      "link": null,
      "locked": false,
      "text": "That updates the ride status in the system\naccordingly.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "That updates the ride status in the system accordingly.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "G5n724Emjad4HMCRPAi5S",
      "type": "text",
      "x": 4282.376301812609,
      "y": 15814.684386709718,
      "width": 537.4067415999622,
      "height": 270,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b6a",
      "roundness": null,
      "seed": 1264449529,
      "version": 304,
      "versionNonce": 777417881,
      "isDeleted": true,
      "boundElements": [
        {
          "id": "OrVTWju27O8Rboh9Yn1TN",
          "type": "arrow"
        }
      ],
      "updated": 1776233033199,
      "link": null,
      "locked": false,
      "text": "Drivers would receive the\nrequest and respond via an\nAPI call to the accept/deny\nendpoint. That would update\nthe ride status in the system\naccordingly.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Drivers would receive the request and respond via an API call to the accept/deny endpoint. That would update the ride status in the system accordingly.",
      "autoResize": false,
      "lineHeight": 1.25
    },
