      "isDeleted": false,
      "boundElements": null,
      "updated": 1776216287953,
      "link": null,
      "locked": false,
      "text": "- consistency for matching - so that ride to driver is 1:1",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "- consistency for matching - so that ride to driver is 1:1",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "Exhw9yuYvDDAhUFOpuIqL",
      "type": "text",
      "x": 2949.4614314733644,
      "y": 2697.639408519242,
      "width": 607.103759765625,
      "height": 360,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aR",
      "roundness": null,
      "seed": 945992793,
      "version": 464,
      "versionNonce": 1835542233,
      "isDeleted": false,
      "boundElements": [
        {
          "id": "diJfVyEEz2-J650H-RugZ",
          "type": "arrow"
        }
      ],
      "updated": 1776216287953,
      "link": null,
      "locked": false,
      "text": "We want to ensure that each \nride is matched to only one driver,\nso the ride-to-driver relationship \nstays one-to-one.\nTo prevent multiple drivers from \ngetting the same ride, strong \nconsistency is critical in this part \nof the system.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "We want to ensure that each \nride is matched to only one driver,\nso the ride-to-driver relationship \nstays one-to-one.\nTo prevent multiple drivers from \ngetting the same ride, strong \nconsistency is critical in this part \nof the system.",
      "autoResize": true,
      "lineHeight": 1.25
    },
