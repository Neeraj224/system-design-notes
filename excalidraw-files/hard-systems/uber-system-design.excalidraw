      "updated": 1776233424724,
      "link": null,
      "locked": false,
      "text": "Each driver record\nwould contain metadata\nlike car, license plate,\nimage, and importantly\nstatus such as\navailable, in-ride, or\noffline.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Each driver record would contain metadata like car, license plate, image, and importantly status such as available, in-ride, or offline.",
      "autoResize": false,
      "lineHeight": 1.25
    },
