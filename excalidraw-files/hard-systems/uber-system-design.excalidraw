      "versionNonce": 1341436695,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1776229897804,
      "link": null,
      "locked": false,
      "text": "Actually Uber uses\na complex ML model\nto estimate ETA and price.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Actually Uber uses\na complex ML model\nto estimate ETA and price.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "oDYtdQdJiyItnv0hSXfJr",
      "type": "text",
      "x": 2376.0791547219355,
      "y": 12354.090263019334,
      "width": 531.4317626953125,
      "height": 180,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b43",
      "roundness": null,
      "seed": 1959101015,
      "version": 697,
      "versionNonce": 386040631,
      "isDeleted": true,
      "boundElements": [
        {
          "id": "wKlWSQ4TWAfibry-TLoc_",
          "type": "arrow"
        }
      ],
      "updated": 1776229900180,
      "link": null,
      "locked": false,
      "text": "For our interview, we will use\na third-party mapping API\nlike Google Maps instead - for\nthe sake of simplicity.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "For our interview, we will use\na third-party mapping API\nlike Google Maps instead - for\nthe sake of simplicity.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "JJW9s_i6tTS6IfZOFS9R9",
      "type": "text",
      "x": 3122.6871474697796,
      "y": 12126.331163814444,
      "width": 577.9797973632812,
      "height": 180,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b44",
      "roundness": null,
      "seed": 934354807,
      "version": 917,
      "versionNonce": 494144409,
      "isDeleted": true,
      "boundElements": [
        {
          "id": "pjtOCSZ58Zj39QcrsDp2z",
          "type": "arrow"
        },
        {
          "id": "wKlWSQ4TWAfibry-TLoc_",
          "type": "arrow"
        }
      ],
      "updated": 1776229897804,
      "link": null,
      "locked": false,
      "text": "It takes source and destination,\nand returns an ETA/estimate to\nget from the source to the\ndestination",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "It takes source and destination,\nand returns an ETA/estimate to\nget from the source to the\ndestination",
      "autoResize": true,
      "lineHeight": 1.25
    },
