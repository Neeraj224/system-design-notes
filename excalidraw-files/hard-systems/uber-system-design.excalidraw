      "link": null,
      "locked": false
    },
    {
      "id": "Q_F_idKKhdRaAi4ifriIc",
      "type": "text",
      "x": 1987.2197438494265,
      "y": 14996.426321603174,
      "width": 600.1604302232331,
      "height": 225,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "dashed",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b5e",
      "roundness": null,
      "seed": 599723385,
      "version": 218,
      "versionNonce": 1947165335,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1776231399082,
      "link": null,
      "locked": false,
      "text": "It takes the previously created\nestimate and starts finding a\nnearby driver based on proximity,\neventually matching the rider to\nan available driver.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "It takes the previously created estimate and starts finding a nearby driver based on proximity, eventually matching the rider to an available driver.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "zJGjLFKmcvi8ALPS8ZpSe",
      "type": "text",
      "x": 1974.7770996022712,
      "y": 15302.49121721195,
      "width": 644.0758056640625,
      "height": 135,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "dashed",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b5f",
      "roundness": null,
      "seed": 2001794649,
      "version": 234,
      "versionNonce": 553580121,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1776231399082,
      "link": null,
      "locked": false,
      "text": "To handle this,\nwe introduce a separate microservice\ncalled the ride matching service.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "To handle this,\nwe introduce a separate microservice\ncalled the ride matching service.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "l2D0ZR-g0qJIe3Qhz0ZaN",
      "type": "text",
      "x": 1974.0325660042665,
      "y": 15467.841233715173,
      "width": 682.19970703125,
      "height": 90,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "dashed",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b5g",
      "roundness": null,
      "seed": 1450361657,
      "version": 261,
      "versionNonce": 726988727,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1776231399082,
      "link": null,
      "locked": false,
      "text": "We split it out because ride estimation\nand ride matching are very different.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "We split it out because ride estimation\nand ride matching are very different.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "QNq31pWcJ0cNiVggdseeF",
      "type": "text",
      "x": 1979.2079824782015,
      "y": 15581.45524483509,
      "width": 748.4250476489019,
      "height": 180,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "dashed",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b5h",
      "roundness": null,
      "seed": 227013657,
      "version": 468,
      "versionNonce": 442549049,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1776231399082,
      "link": null,
      "locked": false,
      "text": "Matching is more computationally heavy\nand happens asynchronously, so separating\nit allows independent scaling and cleaner\nownership across teams.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Matching is more computationally heavy\nand happens asynchronously, so separating\nit allows independent scaling and cleaner\nownership across teams.",
