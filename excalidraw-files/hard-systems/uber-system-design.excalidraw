    {
      "id": "PiPnOdUrBLfpmDRbOqkxF",
      "type": "text",
      "x": 1839.6342661203807,
      "y": 11821.150804516248,
      "width": 782.855712890625,
      "height": 180,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "dashed",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b4W",
      "roundness": null,
      "seed": 1605154775,
      "version": 115,
      "versionNonce": 1482531319,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1776230035004,
      "link": null,
      "locked": false,
      "text": "The next API is when the user accepts the\nfair estimate and requests a ride. This is \nthe point where the actual matching process\nbegins.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The next API is when the user accepts the\nfair estimate and requests a ride. This is \nthe point where the actual matching process\nbegins.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "WiwEAkqWuzHc0NoiiCs8a",
      "type": "text",
      "x": 1847.9185351301853,
      "y": 12068.089567152627,
      "width": 600.1604302232331,
      "height": 225,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "dashed",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b4X",
      "roundness": null,
      "seed": 264991929,
      "version": 139,
      "versionNonce": 509889303,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1776230035004,
      "link": null,
      "locked": false,
      "text": "It takes the previously created\nestimate and starts finding a\nnearby driver based on proximity,\neventually matching the rider to\nan available driver.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "It takes the previously created estimate and starts finding a nearby driver based on proximity, eventually matching the rider to an available driver.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "Zix6bOLSqAOJRSX63SLXr",
      "type": "text",
      "x": 1835.47589088303,
      "y": 12374.154462761402,
      "width": 644.0758056640625,
      "height": 135,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "dashed",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b4Y",
      "roundness": null,
      "seed": 467671161,
      "version": 155,
      "versionNonce": 1180049751,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1776231273764,
      "link": null,
      "locked": false,
      "text": "To handle this,\nwe introduce a separate microservice\ncalled the ride matching service.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "To handle this,\nwe introduce a separate microservice\ncalled the ride matching service.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "XQmjzqKeGVjHlEIVj_hU9",
      "type": "text",
      "x": 1834.7313572850253,
      "y": 12539.504479264624,
      "width": 682.19970703125,
      "height": 90,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "dashed",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b4Z",
      "roundness": null,
      "seed": 1032579383,
      "version": 182,
      "versionNonce": 553926263,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1776230376265,
      "link": null,
      "locked": false,
      "text": "We split it out because ride estimation\nand ride matching are very different.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "We split it out because ride estimation\nand ride matching are very different.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "1iwyYtnfzKbwB-7__vsW5",
      "type": "text",
      "x": 1839.9067737589603,
      "y": 12653.118490384542,
      "width": 748.4250476489019,
      "height": 180,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "dashed",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b4a",
      "roundness": null,
      "seed": 552433177,
      "version": 389,
      "versionNonce": 1412026551,
      "isDeleted": false,
      "boundElements": [
        {
          "id": "VMqM44kQDSgydd7IBqJ-y",
          "type": "arrow"
        }
      ],
      "updated": 1776230478589,
      "link": null,
      "locked": false,
      "text": "Matching is more computationally heavy\nand happens asynchronously, so separating\nit allows independent scaling and cleaner\nownership across teams.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Matching is more computationally heavy\nand happens asynchronously, so separating\nit allows independent scaling and cleaner\nownership across teams.",
      "autoResize": false,
      "lineHeight": 1.25
    },
