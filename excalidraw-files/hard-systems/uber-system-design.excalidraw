    {
      "id": "SD4Yl4t_fRWqKto3thu63",
      "type": "text",
      "x": 3531.8853059184976,
      "y": 10504.569258553556,
      "width": 433.63577154443186,
      "height": 225,
      "angle": 0,
      "strokeColor": "#1971c2",
