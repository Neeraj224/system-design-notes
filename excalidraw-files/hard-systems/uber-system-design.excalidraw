    {
      "id": "EwNmU9c8swJr7RMa8Anc5",
      "type": "text",
      "x": 2433.8217434855846,
      "y": 5674.814027042459,
      "width": 576.3237915039062,
      "height": 360,
      "angle": 0,
      "strokeColor": "#1971c2",
