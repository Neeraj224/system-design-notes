    {
      "id": "iW-zYRpTVZ06ftaqn8uIq",
      "type": "text",
      "x": 2686.1069595087874,
      "y": 16044.10811559007,
      "width": 489.32606653739595,
      "height": 315,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b6S",
      "roundness": null,
      "seed": 1017259641,
      "version": 359,
      "versionNonce": 762530999,
      "isDeleted": false,
      "boundElements": [
        {
          "id": "v_UfouNMuuLOMtop_eZ11",
          "type": "arrow"
        },
        {
          "id": "r3ry8rRAIVcri9REd7-_P",
          "type": "arrow"
        }
      ],
      "updated": 1776233435171,
      "link": null,
      "locked": false,
      "text": "The ride matching service\nthen fetches drivers\nwithin range and removes\nthose who are not available\n(e.g. in-ride or offline) by\ncalling a status check\nbased on driver ID.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The ride matching service then fetches drivers\nwithin range and removes those who are not available\n(e.g. in-ride or offline) by calling a status check\nbased on driver ID.",
      "autoResize": false,
      "lineHeight": 1.25
    },
