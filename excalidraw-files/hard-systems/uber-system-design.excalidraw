    {
      "id": "udLgzXBMF2SJJ0bVDZi0k",
      "type": "text",
      "x": 1655.334923578993,
      "y": 6055.803046721632,
      "width": 786.9237060546875,
      "height": 225,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
