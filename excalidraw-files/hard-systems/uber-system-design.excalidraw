    {
      "id": "zquyAEdz2-XFBgYt1N8oJ",
      "type": "text",
      "x": 2637.881902933044,
      "y": 7321.897771374319,
      "width": 619.9823366001931,
      "height": 450,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0m",
      "roundness": null,
      "seed": 1412872121,
      "version": 761,
      "versionNonce": 1731811223,
      "isDeleted": false,
      "boundElements": [
        {
          "id": "hiA-xT1DEI1-DerbGkYb4",
          "type": "arrow"
        }
      ],
      "updated": 1776222075013,
      "link": null,
      "locked": false,
      "text": "Based on this status, the system\nupdates the ride state and\nreturns the next navigation step.\nIf the driver has picked up \nthe passenger, we return the\ndestination coordinates. \nIf they have completed the trip,\nwe return a 200 success response\nand return NULL (no further\nlocation)",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Based on this status, the system updates the ride state and\nreturns the next navigation step. If the driver has picked up \nthe passenger, we return the destination coordinates. \nIf they have completed the trip, we return a 200 success response and return NULL (no further location)",
      "autoResize": false,
      "lineHeight": 1.25
    },
